@model BotAgendamentoAI.Admin.Models.ServiceEditViewModel
@{
    ViewData["Title"] = "Novo servico";
}

<h1 class="h3 mb-3">Novo servico</h1>

<form asp-action="Create" method="post" class="card card-body">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="TenantId" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="mb-3">
        <label class="form-label">Tenant</label>
        <input asp-for="TenantId" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Titulo</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Categoria</label>
        <input asp-for="CategoryName" class="form-control" list="categories-list" />
        <datalist id="categories-list">
            @foreach (var category in Model.AvailableCategories)
            {
                <option value="@category"></option>
            }
        </datalist>
    </div>

    <div class="mb-3">
        <label class="form-label">Duracao padrao (min)</label>
        <input asp-for="DefaultDurationMinutes" class="form-control" type="number" min="15" max="600" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Ativo</label>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Salvar</button>
        <a asp-action="Index" asp-route-tenant="@Model.TenantId" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>
