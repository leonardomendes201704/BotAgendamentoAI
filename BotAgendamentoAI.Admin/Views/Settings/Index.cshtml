@model BotAgendamentoAI.Admin.Models.BotConfigViewModel
@{
    ViewData["Title"] = "Configuracoes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 m-0">Configuracoes</h1>
    <form method="get" class="d-flex gap-2 align-items-center">
        <label class="form-label m-0">Tenant</label>
        <select name="tenant" class="form-select form-select-sm" style="min-width: 140px">
            @foreach (var tenant in Model.Tenants)
            {
                <option value="@tenant" selected="@(tenant == Model.TenantId)">@tenant</option>
            }
        </select>
        <button class="btn btn-sm btn-primary" type="submit">Carregar</button>
    </form>
</div>

@if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-success">@statusMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form method="post" class="card card-body">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="TenantId" />

    <h2 class="h5">OpenAI (global)</h2>
    <p class="text-muted">Esta chave e compartilhada entre o bot Console e o worker Telegram.</p>

    @if (Model.HasOpenAiApiKey)
    {
        <div class="alert alert-success py-2">
            Chave OpenAI ja configurada.
        </div>
    }
    else
    {
        <div class="alert alert-warning py-2">
            Chave OpenAI ainda nao configurada.
        </div>
    }

    <div class="mb-3">
        <label class="form-label">OpenAI API Key</label>
        <input asp-for="OpenAiApiKey" type="password" class="form-control" autocomplete="new-password" placeholder="sk-proj-..." />
        <small class="text-muted">Se deixar em branco, o valor atual (se existir) sera mantido.</small>
    </div>

    <hr />

    <div class="mb-3">
        <label class="form-label">Menu principal</label>
        <textarea asp-for="MainMenuText" class="form-control" rows="8"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Mensagem de saudacao</label>
        <textarea asp-for="GreetingText" class="form-control" rows="2"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Mensagem de atendente humano</label>
        <textarea asp-for="HumanHandoffText" class="form-control" rows="2"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Mensagem de confirmacao para encerrar atendimento</label>
        <textarea asp-for="CloseConfirmationText" class="form-control" rows="2"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Mensagem de encerramento</label>
        <textarea asp-for="ClosingText" class="form-control" rows="2"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Mensagem fallback</label>
        <textarea asp-for="FallbackText" class="form-control" rows="2"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Janela de pooling (segundos)</label>
        <input asp-for="MessagePoolingSeconds" type="number" class="form-control" min="0" max="120" />
        <small class="text-muted">0 = responde imediatamente. Exemplo recomendado: 15 segundos.</small>
    </div>

    <hr />
    <h2 class="h5">Telegram (Long Polling)</h2>
    <p class="text-muted">Sem HTTPS no seu servidor: use long polling. O worker Telegram consome essa configuracao.</p>

    <div class="mb-3">
        <label class="form-label">Telegram Bot ID</label>
        <input asp-for="TelegramBotId" class="form-control" placeholder="Ex.: 123456789" />
    </div>

    <div class="mb-3">
        <label class="form-label">Telegram Username</label>
        <input asp-for="TelegramBotUsername" class="form-control" placeholder="Ex.: MeuBot" />
    </div>

    <div class="mb-3">
        <label class="form-label">Telegram Bot Token</label>
        <input asp-for="TelegramBotToken" type="password" class="form-control" autocomplete="new-password" placeholder="Ex.: 123456:ABC..." />
        <small class="text-muted">Se deixar em branco, o sistema mantem o token ja salvo.</small>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-sm-6">
            <label class="form-label">Timeout polling (segundos)</label>
            <input asp-for="TelegramPollingTimeoutSeconds" type="number" class="form-control" min="5" max="50" />
        </div>
        <div class="col-sm-6">
            <label class="form-label">Ultimo update processado</label>
            <input asp-for="TelegramLastUpdateId" type="number" class="form-control" min="0" />
        </div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="TelegramIsActive" class="form-check-input" />
        <label asp-for="TelegramIsActive" class="form-check-label">Ativar integracao Telegram para este tenant</label>
    </div>

    <hr />
    <h2 class="h5">WhatsApp Cloud API</h2>
    <p class="text-muted">Configuracao do canal WhatsApp oficial. O webhook sera validado usando o token e o App Secret cadastrados aqui.</p>
    <p class="text-muted">Webhook fixo deste projeto: <code>/webhooks/whatsapp</code>.</p>

    <div class="form-check mb-3">
        <input asp-for="WhatsAppIsActive" class="form-check-input" />
        <label asp-for="WhatsAppIsActive" class="form-check-label">Ativar integracao WhatsApp para este tenant</label>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-sm-6">
            <label class="form-label">Phone Number ID</label>
            <input asp-for="WhatsAppPhoneNumberId" class="form-control" placeholder="Ex.: 1007250472474601" />
        </div>
        <div class="col-sm-6">
            <label class="form-label">WhatsApp Business Account ID</label>
            <input asp-for="WhatsAppBusinessAccountId" class="form-control" placeholder="Ex.: 1568473064258780" />
        </div>
    </div>

    @if (Model.HasWhatsAppAccessToken)
    {
        <div class="alert alert-success py-2">
            Access Token do WhatsApp ja configurado.
        </div>
    }
    else
    {
        <div class="alert alert-warning py-2">
            Access Token do WhatsApp ainda nao configurado.
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Access Token</label>
        <input asp-for="WhatsAppAccessToken" type="password" class="form-control" autocomplete="new-password" placeholder="EA..." />
        <small class="text-muted">Se deixar em branco, o valor atual (se existir) sera mantido.</small>
    </div>

    @if (Model.HasWhatsAppAppSecret)
    {
        <div class="alert alert-success py-2">
            App Secret do WhatsApp ja configurado.
        </div>
    }
    else
    {
        <div class="alert alert-warning py-2">
            App Secret do WhatsApp ainda nao configurado.
        </div>
    }

    <div class="mb-3">
        <label class="form-label">App Secret</label>
        <input asp-for="WhatsAppAppSecret" type="password" class="form-control" autocomplete="new-password" placeholder="App Secret da Meta" />
        <small class="text-muted">Se deixar em branco, o valor atual (se existir) sera mantido.</small>
    </div>

    @if (Model.HasWhatsAppWebhookVerifyToken)
    {
        <div class="alert alert-success py-2">
            Verify Token do webhook ja configurado.
        </div>
    }
    else
    {
        <div class="alert alert-warning py-2">
            Verify Token do webhook ainda nao configurado.
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Webhook Verify Token</label>
        <input asp-for="WhatsAppWebhookVerifyToken" type="password" class="form-control" autocomplete="new-password" placeholder="Token de verificacao do webhook" />
        <small class="text-muted">Se deixar em branco, o valor atual (se existir) sera mantido.</small>
    </div>

    <hr />
    <h2 class="h5">Lembrete de perfil do prestador</h2>
    <p class="text-muted">Parametros do worker que lembra prestadores com perfil incompleto (categorias, raio e CEP/local base).</p>

    <div class="form-check mb-3">
        <input asp-for="ProviderReminderEnabled" class="form-check-input" />
        <label asp-for="ProviderReminderEnabled" class="form-check-label">Ativar lembretes automaticos para prestadores</label>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-sm-4">
            <label class="form-label">Varredura (minutos)</label>
            <input asp-for="ProviderReminderSweepIntervalMinutes" type="number" class="form-control" min="1" max="1440" />
            <small class="text-muted">A cada quantos minutos o worker tenta enviar lembretes.</small>
        </div>
        <div class="col-sm-4">
            <label class="form-label">Cooldown entre lembretes (min)</label>
            <input asp-for="ProviderReminderResendCooldownMinutes" type="number" class="form-control" min="1" max="1440" />
            <small class="text-muted">Tempo minimo entre dois lembretes para o mesmo prestador.</small>
        </div>
        <div class="col-sm-4">
            <label class="form-label">Soneca do "Fazer mais tarde" (horas)</label>
            <input asp-for="ProviderReminderSnoozeHours" type="number" class="form-control" min="1" max="168" />
            <small class="text-muted">Tempo de pausa quando o prestador escolhe "Fazer mais tarde".</small>
        </div>
    </div>

    <hr />
    <h2 class="h5">Google Calendar</h2>
    <p class="text-muted">Integra com Google Calendar via Service Account para criar/atualizar/cancelar eventos dos agendamentos.</p>

    <div class="form-check mb-3">
        <input asp-for="GoogleCalendarEnabled" class="form-check-input" />
        <label asp-for="GoogleCalendarEnabled" class="form-check-label">Ativar sincronizacao com Google Calendar para este tenant</label>
    </div>

    <div class="mb-3">
        <label class="form-label">Calendar ID</label>
        <input asp-for="GoogleCalendarId" class="form-control" placeholder="Ex.: primary ou calendario@group.calendar.google.com" />
    </div>

    @if (Model.HasGoogleCalendarServiceAccountJson)
    {
        <div class="alert alert-success py-2">
            Credencial Service Account ja configurada.
        </div>
    }
    else
    {
        <div class="alert alert-warning py-2">
            Credencial Service Account ainda nao configurada.
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Service Account JSON</label>
        <textarea asp-for="GoogleCalendarServiceAccountJson" class="form-control" rows="6" placeholder="{ ... }"></textarea>
        <small class="text-muted">Se deixar em branco, o valor atual (se existir) sera mantido.</small>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-sm-6">
            <label class="form-label">Timezone do calendario</label>
            <input asp-for="GoogleCalendarTimeZoneId" class="form-control" placeholder="America/Sao_Paulo" />
        </div>
        <div class="col-sm-6">
            <label class="form-label">Duracao padrao (minutos)</label>
            <input asp-for="GoogleCalendarDefaultDurationMinutes" type="number" class="form-control" min="15" max="720" />
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-sm-4">
            <label class="form-label">Tentativas maximas</label>
            <input asp-for="GoogleCalendarMaxAttempts" type="number" class="form-control" min="1" max="30" />
        </div>
        <div class="col-sm-4">
            <label class="form-label">Retry base (segundos)</label>
            <input asp-for="GoogleCalendarRetryBaseSeconds" type="number" class="form-control" min="5" max="600" />
        </div>
        <div class="col-sm-4">
            <label class="form-label">Retry maximo (segundos)</label>
            <input asp-for="GoogleCalendarRetryMaxSeconds" type="number" class="form-control" min="10" max="86400" />
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-sm-4">
            <label class="form-label">Janela de dias (agenda)</label>
            <input asp-for="GoogleCalendarAvailabilityWindowDays" type="number" class="form-control" min="1" max="30" />
        </div>
        <div class="col-sm-4">
            <label class="form-label">Intervalo de slot (min)</label>
            <input asp-for="GoogleCalendarAvailabilitySlotIntervalMinutes" type="number" class="form-control" min="15" max="240" />
        </div>
        <div class="col-sm-4">
            <label class="form-label">Lead hoje (min)</label>
            <input asp-for="GoogleCalendarAvailabilityTodayLeadMinutes" type="number" class="form-control" min="0" max="720" />
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-sm-6">
            <label class="form-label">Hora inicio expediente</label>
            <input asp-for="GoogleCalendarAvailabilityWorkdayStartHour" type="number" class="form-control" min="0" max="23" />
        </div>
        <div class="col-sm-6">
            <label class="form-label">Hora fim expediente</label>
            <input asp-for="GoogleCalendarAvailabilityWorkdayEndHour" type="number" class="form-control" min="1" max="24" />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Template do titulo do evento</label>
        <input asp-for="GoogleCalendarEventTitleTemplate" class="form-control" />
        <small class="text-muted">Placeholders: {job_id}, {category}, {status}, {tenant_id}</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Template da descricao do evento</label>
        <textarea asp-for="GoogleCalendarEventDescriptionTemplate" class="form-control" rows="5"></textarea>
        <small class="text-muted">Placeholders: {job_id}, {category}, {description}, {status}, {client_name}, {client_phone}, {provider_name}, {address}, {scheduled_at_local}, {tenant_id}</small>
    </div>

    <div>
        <button type="submit" class="btn btn-primary">Salvar</button>
    </div>
</form>

<form method="post" asp-action="ResetTelegramMemory" class="card card-body mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="tenantId" value="@Model.TenantId" />

    <h2 class="h5">Reset de memoria (Telegram)</h2>
    <p class="text-muted">
        Use para limpar estado e historico de um usuario especifico no tenant atual.
        Isso ajuda nos testes quando o mesmo Telegram fica preso em um fluxo anterior.
    </p>

    @if (Model.TelegramUsers.Count == 0)
    {
        <div class="alert alert-warning py-2 mb-3">
            Nenhum usuario Telegram encontrado para este tenant. Envie ao menos uma mensagem no bot para o usuario aparecer aqui.
        </div>
    }
    else
    {
        <div class="mb-3">
            <label class="form-label">Usuario Telegram</label>
            <select name="telegramUserId" class="form-select" required>
                <option value="">Selecione um usuario...</option>
                @foreach (var option in Model.TelegramUsers)
                {
                    <option value="@option.TelegramUserId">@option.DisplayLabel</option>
                }
            </select>
        </div>
    }

    <input type="hidden" name="clearHistory" value="false" />
    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" name="clearHistory" value="true" checked id="clearHistoryFlag" />
        <label class="form-check-label" for="clearHistoryFlag">
            Limpar historico de mensagens junto com a sessao
        </label>
    </div>

    <div>
        <button type="submit" class="btn btn-outline-danger" @(Model.TelegramUsers.Count == 0 ? "disabled" : null)>Resetar memoria do usuario</button>
    </div>
</form>

<form method="post" asp-action="ResetTenantOperationalData" class="card card-body mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="tenantId" value="@Model.TenantId" />

    <h2 class="h5">Reset geral do tenant</h2>
    <p class="text-muted mb-2">
        Limpa todos os dados operacionais do tenant atual (conversas, estados, logs, agendamentos/jobs, usuarios/sessoes).
        As configuracoes sao preservadas (menus/mensagens, token Telegram, OpenAI API Key, catalogo de servicos/categorias).
    </p>

    <div class="alert alert-warning py-2 mb-3">
        Esta acao e irreversivel.
    </div>

    <div>
        <button type="submit" class="btn btn-danger" onclick="return confirm('Confirmar reset geral do tenant @Model.TenantId? Esta acao nao pode ser desfeita.');">
            Reset geral (manter configuracoes)
        </button>
    </div>
</form>
