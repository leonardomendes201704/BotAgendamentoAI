@model BotAgendamentoAI.Admin.Models.ConversationDetailsViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Detalhes da conversa";
    var visibleMessages = Model.Messages
        .Where(message => !string.Equals(message.Role, "tool", StringComparison.OrdinalIgnoreCase))
        .ToList();
    var realtimeLimit = (int?)ViewData["Limit"] ?? 250;
    var initialHandoff = Model.Handoff ?? new BotAgendamentoAI.Admin.Models.ConversationHandoffStatus
    {
        TenantId = Model.TenantId,
        Phone = Model.Phone
    };
}

@functions {
    private static string DeliveryStatusLabel(string? status)
    {
        return (status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "accepted" => "Aceita",
            "sent" => "Enviada",
            "delivered" => "Entregue",
            "read" => "Lida",
            "failed" => "Falhou",
            _ => string.IsNullOrWhiteSpace(status) ? string.Empty : status.Trim()
        };
    }

    private static string DeliveryStatusBadgeClass(string? status)
    {
        return (status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "accepted" => "text-bg-info",
            "sent" => "text-bg-secondary",
            "delivered" => "text-bg-success",
            "read" => "text-bg-primary",
            "failed" => "text-bg-danger",
            _ => "text-bg-secondary"
        };
    }
}

<style>
    .conversation-chat-card {
        border: 1px solid #dce5eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .conversation-chat-track {
        max-height: 72vh;
        overflow-y: auto;
        padding: 1rem;
        background:
            radial-gradient(circle at 1px 1px, rgba(35, 42, 54, 0.06) 1px, transparent 0) 0 0/16px 16px,
            linear-gradient(180deg, #eef4f8 0%, #e7eef3 100%);
    }

    .chat-row {
        display: flex;
        margin-bottom: 0.65rem;
    }

    .chat-left {
        justify-content: flex-start;
    }

    .chat-right {
        justify-content: flex-end;
    }

    .chat-bubble {
        max-width: min(78%, 820px);
        border-radius: 12px;
        padding: 0.5rem 0.7rem;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .chat-bubble-in {
        background: #ffffff;
        border-top-left-radius: 4px;
    }

    .chat-bubble-out {
        background: #dcf8c6;
        border-top-right-radius: 4px;
    }

    .chat-meta {
        display: flex;
        gap: 0.4rem;
        align-items: center;
        margin-bottom: 0.35rem;
        font-size: 0.75rem;
        color: #556170;
    }

    .chat-sender {
        color: #000000;
        font-weight: 700;
    }

    .chat-content {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
        font-size: 0.92rem;
        color: #1f2a33;
    }

    .chat-delivery {
        margin-top: 0.45rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: center;
        font-size: 0.75rem;
        color: #556170;
    }

    .chat-delivery-error {
        margin-top: 0.35rem;
        font-size: 0.8rem;
        color: #a61e2f;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .chat-empty {
        text-align: center;
        color: #6b7785;
        padding: 2rem 1rem;
    }

    .realtime-toggle-btn {
        min-width: 150px;
    }

    .handoff-status-card {
        border: 1px solid #dce5eb;
    }

    .wizard-step {
        display: none;
    }

    .wizard-step.active {
        display: block;
    }

    .wizard-progress-badge {
        min-width: 2rem;
    }

    .wizard-summary {
        white-space: pre-wrap;
        font-size: 0.95rem;
        color: #1f2a33;
        background: #f8fbfd;
        border: 1px solid #dce5eb;
        border-radius: 12px;
        padding: 1rem;
    }

    .wizard-muted-box {
        border: 1px dashed #c5d1db;
        border-radius: 12px;
        padding: 0.9rem 1rem;
        background: #fbfdff;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 m-0">Conversa @Model.Phone</h1>
    <div class="d-flex gap-2 align-items-center">
        <span id="realtimeStatusBadge" class="badge text-bg-secondary">Realtime desligado</span>
        <button id="realtimeToggleBtn" type="button" class="btn btn-sm btn-outline-primary realtime-toggle-btn">Ligar realtime</button>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index" asp-route-tenant="@Model.TenantId">Voltar</a>
    </div>
</div>

<div class="card handoff-status-card mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <div class="text-muted small">Atendimento humano</div>
                <div class="d-flex align-items-center gap-2">
                    <span id="handoffStatusBadge" class="badge text-bg-secondary">Fechado</span>
                    <small id="handoffMeta" class="text-muted">Sem atendimento ativo.</small>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button id="orderAssistBtn" type="button" class="btn btn-sm btn-outline-primary">Abrir pedido</button>
                <button id="handoffOpenBtn" type="button" class="btn btn-sm btn-outline-success">Iniciar atendimento</button>
                <button id="handoffCloseBtn" type="button" class="btn btn-sm btn-outline-danger">Encerrar atendimento</button>
            </div>
        </div>

        <div id="handoffNotTelegramAlert" class="alert alert-info py-2 px-3 mt-3 mb-0 d-none">
            Intervencao humana disponivel apenas para conversas Telegram (formato tg:&lt;id&gt;).
        </div>

        <div class="mt-3">
            <div class="small text-muted mb-2">
                Pedido assistido: o atendente monta o pedido aqui e o cliente recebe no Telegram somente a confirmacao final.
            </div>
            <label class="form-label" for="humanMessageInput">Mensagem do atendente</label>
            <textarea id="humanMessageInput" class="form-control" rows="3" maxlength="1200" placeholder="Digite a mensagem para o cliente ou prestador..."></textarea>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small id="humanSendStatus" class="text-muted"></small>
                <button id="humanSendBtn" type="button" class="btn btn-sm btn-primary">Enviar mensagem</button>
            </div>
        </div>
    </div>
</div>

<div class="card conversation-chat-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Historico</strong>
        <small id="realtimeUpdatedAt" class="text-muted">Ultima atualizacao: carregando...</small>
    </div>
    <div id="chatTrack" class="conversation-chat-track">
        <div id="chatRows">
            @if (visibleMessages.Count == 0)
            {
                <div class="chat-empty">Sem mensagens visiveis para esta conversa.</div>
            }
            else
            {
                @foreach (var message in visibleMessages)
                {
                    var isInbound = string.Equals(message.Direction, "in", StringComparison.OrdinalIgnoreCase);
                    var bubbleClass = isInbound ? "chat-bubble-in" : "chat-bubble-out";
                    var rowClass = isInbound ? "chat-left" : "chat-right";
                    var roleLower = (message.Role ?? string.Empty).Trim().ToLowerInvariant();
                    var roleBadgeClass = roleLower switch
                    {
                        "assistant" => "text-bg-primary",
                        "human" => "text-bg-info",
                        "system" => "text-bg-warning",
                        _ => "text-bg-secondary"
                    };
                    var senderName = isInbound
                        ? "Cliente"
                        : roleLower == "human"
                            ? "Atendente"
                            : "Bot";

                    <div class="chat-row @rowClass">
                        <div class="chat-bubble @bubbleClass">
                            <div class="chat-meta">
                                <span class="badge @roleBadgeClass">@message.Role</span>
                                <span class="chat-sender">@senderName</span>
                                <span>@message.CreatedAtUtc.ToLocalTime().ToString("dd/MM HH:mm:ss")</span>
                            </div>
                            <p class="chat-content">@message.Content</p>
                            @if (!isInbound && !string.IsNullOrWhiteSpace(message.DeliveryStatus))
                            {
                                <div class="chat-delivery">
                                    <span class="badge @DeliveryStatusBadgeClass(message.DeliveryStatus)">@DeliveryStatusLabel(message.DeliveryStatus)</span>
                                    @if (message.DeliveryStatusAtUtc.HasValue)
                                    {
                                        <span>@message.DeliveryStatusAtUtc.Value.ToLocalTime().ToString("dd/MM HH:mm:ss")</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(message.DeliveryError))
                                {
                                    <div class="chat-delivery-error">@message.DeliveryError</div>
                                }
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="modal fade" id="assistOrderModal" tabindex="-1" aria-labelledby="assistOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h2 id="assistOrderModalLabel" class="h5 mb-1">Abrir pedido assistido</h2>
                    <div class="text-muted small">O cliente recebe no Telegram o resumo final para confirmar, editar ou cancelar.</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex flex-wrap gap-2 mb-3" id="orderWizardProgress">
                    <span class="badge text-bg-primary wizard-progress-badge" data-step-badge="0">1</span>
                    <span class="badge text-bg-secondary wizard-progress-badge" data-step-badge="1">2</span>
                    <span class="badge text-bg-secondary wizard-progress-badge" data-step-badge="2">3</span>
                    <span class="badge text-bg-secondary wizard-progress-badge" data-step-badge="3">4</span>
                    <span class="badge text-bg-secondary wizard-progress-badge" data-step-badge="4">5</span>
                    <span class="badge text-bg-secondary wizard-progress-badge" data-step-badge="5">6</span>
                </div>

                <div id="orderWizardAlert" class="alert alert-danger d-none"></div>

                <div class="wizard-step active" data-order-step="0">
                    <h3 class="h6">1. Servico</h3>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="orderCategory">Categoria</label>
                            <select id="orderCategory" class="form-select"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="orderDescription">Descricao do problema</label>
                            <textarea id="orderDescription" class="form-control" rows="4" maxlength="2000" placeholder="Descreva o que precisa ser resolvido."></textarea>
                        </div>
                    </div>
                </div>

                <div class="wizard-step" data-order-step="1">
                    <h3 class="h6">2. Endereco</h3>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="orderCep">CEP</label>
                            <div class="input-group">
                                <input id="orderCep" class="form-control" maxlength="9" placeholder="00000-000" />
                                <button id="orderResolveCepBtn" type="button" class="btn btn-outline-secondary">Resolver CEP</button>
                            </div>
                            <div id="orderCepHelp" class="form-text">Os dados do endereco sao resolvidos pelo CEP; informe apenas numero e complemento.</div>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label" for="orderStreet">Logradouro</label>
                            <input id="orderStreet" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="orderNumber">Numero</label>
                            <input id="orderNumber" class="form-control" maxlength="20" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="orderComplement">Complemento</label>
                            <input id="orderComplement" class="form-control" maxlength="80" placeholder="Opcional" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="orderNeighborhood">Bairro</label>
                            <input id="orderNeighborhood" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="orderCity">Cidade</label>
                            <input id="orderCity" class="form-control" />
                        </div>
                        <div class="col-md-1">
                            <label class="form-label" for="orderState">UF</label>
                            <input id="orderState" class="form-control text-uppercase" maxlength="2" />
                        </div>
                        <div class="col-12">
                            <div class="wizard-muted-box">
                                <div class="small text-muted mb-1">Previa do endereco</div>
                                <div id="orderAddressPreview" class="fw-semibold">Resolva o CEP para montar o endereco.</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input id="orderAddressConfirmed" class="form-check-input" type="checkbox" />
                                <label class="form-check-label" for="orderAddressConfirmed">Confirmo que o endereco esta correto.</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="wizard-step" data-order-step="2">
                    <h3 class="h6">3. Quando</h3>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="orderScheduleMode" id="orderScheduleUrgent" value="URG">
                                <label class="form-check-label" for="orderScheduleUrgent">Urgente</label>
                            </div>
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="radio" name="orderScheduleMode" id="orderScheduleToday" value="TOD" checked>
                                <label class="form-check-label" for="orderScheduleToday">Hoje no proximo horario</label>
                            </div>
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="radio" name="orderScheduleMode" id="orderScheduleCalendar" value="CAL">
                                <label class="form-check-label" for="orderScheduleCalendar">Agendar data e hora</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="orderScheduledAt">Data/hora</label>
                            <input id="orderScheduledAt" type="datetime-local" class="form-control" disabled />
                            <div class="form-text">Obrigatorio apenas quando a opcao "Agendar data e hora" estiver selecionada.</div>
                        </div>
                        <div class="col-md-4">
                            <div class="wizard-muted-box">
                                <div class="small text-muted mb-1">Observacao</div>
                                <div>Antes de confirmar, o cliente ainda pode tocar em <strong>Editar</strong> no Telegram e ajustar o horario.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="wizard-step" data-order-step="3">
                    <h3 class="h6">4. Preferencia</h3>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="orderPreference">Regra de distribuicao</label>
                            <select id="orderPreference" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <div class="wizard-muted-box">
                                <div class="small text-muted mb-1">Fotos</div>
                                <div>Neste modo assistido, as fotos nao sao enviadas pelo Admin. Se precisar, o cliente pode tocar em <strong>Editar</strong> no Telegram e anexar as imagens antes de confirmar.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="wizard-step" data-order-step="4">
                    <h3 class="h6">5. Contato</h3>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="orderContactName">Nome do contato</label>
                            <input id="orderContactName" class="form-control" maxlength="120" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="orderContactPhone">Telefone do contato</label>
                            <input id="orderContactPhone" class="form-control" maxlength="30" />
                        </div>
                    </div>
                </div>

                <div class="wizard-step" data-order-step="5">
                    <h3 class="h6">6. Revisao</h3>
                    <div class="wizard-summary" id="orderSummaryBox"></div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <small id="orderWizardStatus" class="text-muted"></small>
                <div class="d-flex gap-2">
                    <button id="orderWizardPrevBtn" type="button" class="btn btn-outline-secondary">Voltar</button>
                    <button id="orderWizardNextBtn" type="button" class="btn btn-primary">Avancar</button>
                    <button id="orderWizardSubmitBtn" type="button" class="btn btn-success d-none">Enviar para confirmacao do cliente</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const tenantId = @Html.Raw(JsonSerializer.Serialize(Model.TenantId));
            const phone = @Html.Raw(JsonSerializer.Serialize(Model.Phone));
            const snapshotLimit = @realtimeLimit;
            const snapshotEndpoint = '@Url.Action("Snapshot", "Conversations")';
            const handoffOpenEndpoint = '@Url.Action("HandoffOpen", "Conversations")';
            const handoffCloseEndpoint = '@Url.Action("HandoffClose", "Conversations")';
            const sendHumanEndpoint = '@Url.Action("SendHumanMessage", "Conversations")';
            const orderWizardBootstrapEndpoint = '@Url.Action("OrderWizardBootstrap", "Conversations")';
            const orderResolveCepEndpoint = '@Url.Action("ResolveCep", "Conversations")';
            const createAssistedOrderEndpoint = '@Url.Action("CreateAssistedOrder", "Conversations")';
            const initialMessages = @Html.Raw(JsonSerializer.Serialize(
                visibleMessages.Select(message => new
                {
                    id = message.Id,
                    direction = message.Direction,
                    role = message.Role,
                    content = message.Content,
                    createdAtUtc = message.CreatedAtUtc.ToString("O"),
                    deliveryStatus = message.DeliveryStatus,
                    deliveryError = message.DeliveryError,
                    deliveryStatusAtUtc = message.DeliveryStatusAtUtc?.ToString("O")
                })));
            const initialHandoff = @Html.Raw(JsonSerializer.Serialize(new
            {
                tenantId = initialHandoff.TenantId,
                phone = initialHandoff.Phone,
                isTelegramThread = initialHandoff.IsTelegramThread,
                isOpen = initialHandoff.IsOpen,
                requestedByRole = initialHandoff.RequestedByRole,
                assignedAgent = initialHandoff.AssignedAgent,
                previousState = initialHandoff.PreviousState,
                closeReason = initialHandoff.CloseReason,
                requestedAtUtc = initialHandoff.RequestedAtUtc?.ToString("O"),
                acceptedAtUtc = initialHandoff.AcceptedAtUtc?.ToString("O"),
                closedAtUtc = initialHandoff.ClosedAtUtc?.ToString("O"),
                lastMessageAtUtc = initialHandoff.LastMessageAtUtc?.ToString("O")
            }));

            const chatTrack = document.getElementById('chatTrack');
            const chatRows = document.getElementById('chatRows');
            const realtimeToggleBtn = document.getElementById('realtimeToggleBtn');
            const realtimeStatusBadge = document.getElementById('realtimeStatusBadge');
            const realtimeUpdatedAt = document.getElementById('realtimeUpdatedAt');
            const handoffStatusBadge = document.getElementById('handoffStatusBadge');
            const handoffMeta = document.getElementById('handoffMeta');
            const handoffOpenBtn = document.getElementById('handoffOpenBtn');
            const handoffCloseBtn = document.getElementById('handoffCloseBtn');
            const handoffNotTelegramAlert = document.getElementById('handoffNotTelegramAlert');
            const humanMessageInput = document.getElementById('humanMessageInput');
            const humanSendBtn = document.getElementById('humanSendBtn');
            const humanSendStatus = document.getElementById('humanSendStatus');
            const orderAssistBtn = document.getElementById('orderAssistBtn');
            const assistOrderModalElement = document.getElementById('assistOrderModal');
            const orderWizardAlert = document.getElementById('orderWizardAlert');
            const orderWizardStatus = document.getElementById('orderWizardStatus');
            const orderWizardPrevBtn = document.getElementById('orderWizardPrevBtn');
            const orderWizardNextBtn = document.getElementById('orderWizardNextBtn');
            const orderWizardSubmitBtn = document.getElementById('orderWizardSubmitBtn');
            const orderWizardProgressBadges = Array.from(document.querySelectorAll('[data-step-badge]'));
            const orderWizardSteps = Array.from(document.querySelectorAll('[data-order-step]'));
            const orderCategory = document.getElementById('orderCategory');
            const orderDescription = document.getElementById('orderDescription');
            const orderCep = document.getElementById('orderCep');
            const orderResolveCepBtn = document.getElementById('orderResolveCepBtn');
            const orderStreet = document.getElementById('orderStreet');
            const orderNumber = document.getElementById('orderNumber');
            const orderComplement = document.getElementById('orderComplement');
            const orderNeighborhood = document.getElementById('orderNeighborhood');
            const orderCity = document.getElementById('orderCity');
            const orderState = document.getElementById('orderState');
            const orderAddressPreview = document.getElementById('orderAddressPreview');
            const orderAddressConfirmed = document.getElementById('orderAddressConfirmed');
            const orderScheduledAt = document.getElementById('orderScheduledAt');
            const orderPreference = document.getElementById('orderPreference');
            const orderContactName = document.getElementById('orderContactName');
            const orderContactPhone = document.getElementById('orderContactPhone');
            const orderSummaryBox = document.getElementById('orderSummaryBox');
            const storageKey = `conversation-realtime:${tenantId}:${phone}`;
            const assistOrderModal = assistOrderModalElement && window.bootstrap
                ? new bootstrap.Modal(assistOrderModalElement)
                : null;

            let realtimeConnection = null;
            let realtimeEnabled = true;
            let isRefreshing = false;
            let lastSignature = '';
            let lastHandoffSignature = '';
            let currentHandoff = normalizeHandoff(initialHandoff);
            let orderWizardBootstrap = null;
            let orderWizardStepIndex = 0;
            let orderWizardBusy = false;

            try {
                const storedValue = window.localStorage.getItem(storageKey);
                realtimeEnabled = storedValue !== 'off';
            } catch {
                realtimeEnabled = true;
            }

            function saveRealtimePreference(enabled) {
                try {
                    window.localStorage.setItem(storageKey, enabled ? 'on' : 'off');
                } catch {
                    // ignore
                }
            }

            function escapeHtml(value) {
                return (value ?? '')
                    .toString()
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function isInboundDirection(direction) {
                const normalized = (direction ?? '').toString().trim().toLowerCase();
                return normalized === 'in' || normalized === 'inbound' || normalized === 'incoming';
            }

            function toRoleBadgeClass(role) {
                const normalized = (role ?? '').toString().trim().toLowerCase();
                if (normalized === 'assistant') {
                    return 'text-bg-primary';
                }

                if (normalized === 'human') {
                    return 'text-bg-info';
                }

                if (normalized === 'system') {
                    return 'text-bg-warning';
                }

                return 'text-bg-secondary';
            }

            function formatDateTime(value) {
                const parsed = new Date(value ?? '');
                if (Number.isNaN(parsed.getTime())) {
                    return '-';
                }

                return parsed.toLocaleString('pt-BR', {
                    day: '2-digit',
                    month: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit'
                });
            }

            function normalizeMessages(rawItems) {
                if (!Array.isArray(rawItems)) {
                    return [];
                }

                return rawItems
                    .map(raw => ({
                        id: raw.id ?? raw.Id ?? 0,
                        direction: raw.direction ?? raw.Direction ?? '',
                        role: raw.role ?? raw.Role ?? '',
                        content: raw.content ?? raw.Content ?? '',
                        createdAtUtc: raw.createdAtUtc ?? raw.CreatedAtUtc ?? '',
                        deliveryStatus: raw.deliveryStatus ?? raw.DeliveryStatus ?? '',
                        deliveryError: raw.deliveryError ?? raw.DeliveryError ?? '',
                        deliveryStatusAtUtc: raw.deliveryStatusAtUtc ?? raw.DeliveryStatusAtUtc ?? ''
                    }))
                    .filter(item => (item.role ?? '').toString().trim().toLowerCase() !== 'tool');
            }

            function deliveryStatusLabel(status) {
                switch (String(status ?? '').trim().toLowerCase()) {
                    case 'accepted':
                        return 'Aceita';
                    case 'sent':
                        return 'Enviada';
                    case 'delivered':
                        return 'Entregue';
                    case 'read':
                        return 'Lida';
                    case 'failed':
                        return 'Falhou';
                    default:
                        return String(status ?? '').trim();
                }
            }

            function deliveryStatusBadgeClass(status) {
                switch (String(status ?? '').trim().toLowerCase()) {
                    case 'accepted':
                        return 'text-bg-info';
                    case 'sent':
                        return 'text-bg-secondary';
                    case 'delivered':
                        return 'text-bg-success';
                    case 'read':
                        return 'text-bg-primary';
                    case 'failed':
                        return 'text-bg-danger';
                    default:
                        return 'text-bg-secondary';
                }
            }

            function normalizeHandoff(raw) {
                const source = raw ?? {};
                return {
                    tenantId: (source.tenantId ?? source.TenantId ?? tenantId ?? '').toString(),
                    phone: (source.phone ?? source.Phone ?? phone ?? '').toString(),
                    isTelegramThread: !!(source.isTelegramThread ?? source.IsTelegramThread),
                    isOpen: !!(source.isOpen ?? source.IsOpen),
                    requestedByRole: (source.requestedByRole ?? source.RequestedByRole ?? '').toString(),
                    assignedAgent: (source.assignedAgent ?? source.AssignedAgent ?? '').toString(),
                    previousState: (source.previousState ?? source.PreviousState ?? '').toString(),
                    closeReason: (source.closeReason ?? source.CloseReason ?? '').toString(),
                    requestedAtUtc: source.requestedAtUtc ?? source.RequestedAtUtc ?? null,
                    acceptedAtUtc: source.acceptedAtUtc ?? source.AcceptedAtUtc ?? null,
                    closedAtUtc: source.closedAtUtc ?? source.ClosedAtUtc ?? null,
                    lastMessageAtUtc: source.lastMessageAtUtc ?? source.LastMessageAtUtc ?? null
                };
            }

            function buildSignature(messages) {
                if (!Array.isArray(messages) || messages.length === 0) {
                    return '0';
                }

                return messages
                    .map(message => `${message.id}|${message.createdAtUtc}|${(message.content ?? '').length}|${message.role}|${message.deliveryStatus ?? ''}|${message.deliveryError ?? ''}|${message.deliveryStatusAtUtc ?? ''}`)
                    .join('||');
            }

            function buildHandoffSignature(handoff) {
                const normalized = normalizeHandoff(handoff);
                return [
                    normalized.isTelegramThread ? '1' : '0',
                    normalized.isOpen ? '1' : '0',
                    normalized.requestedAtUtc ?? '',
                    normalized.acceptedAtUtc ?? '',
                    normalized.closedAtUtc ?? '',
                    normalized.lastMessageAtUtc ?? '',
                    normalized.assignedAgent ?? ''
                ].join('|');
            }

            function setHumanSendStatus(text, isError) {
                if (!humanSendStatus) {
                    return;
                }

                humanSendStatus.textContent = text ?? '';
                humanSendStatus.className = isError ? 'text-danger' : 'text-muted';
            }

            function renderHandoff(rawStatus) {
                const status = normalizeHandoff(rawStatus);
                currentHandoff = status;

                if (handoffStatusBadge) {
                    handoffStatusBadge.textContent = status.isOpen ? 'Atendimento ativo' : 'Atendimento fechado';
                    handoffStatusBadge.className = status.isOpen ? 'badge text-bg-success' : 'badge text-bg-secondary';
                }

                if (handoffMeta) {
                    if (!status.isTelegramThread) {
                        handoffMeta.textContent = 'Conversa fora do canal Telegram.';
                    } else if (status.isOpen) {
                        const assigned = status.assignedAgent ? ` | Atendente: ${status.assignedAgent}` : '';
                        handoffMeta.textContent = `Aberto em ${formatDateTime(status.requestedAtUtc)}${assigned}`;
                    } else {
                        handoffMeta.textContent = status.closedAtUtc
                            ? `Ultimo encerramento: ${formatDateTime(status.closedAtUtc)}.`
                            : 'Sem atendimento ativo.';
                    }
                }

                if (handoffNotTelegramAlert) {
                    handoffNotTelegramAlert.classList.toggle('d-none', status.isTelegramThread);
                }

                if (handoffOpenBtn) {
                    handoffOpenBtn.disabled = !status.isTelegramThread || status.isOpen;
                }

                if (handoffCloseBtn) {
                    handoffCloseBtn.disabled = !status.isTelegramThread || !status.isOpen;
                }

                if (humanMessageInput) {
                    humanMessageInput.disabled = !status.isTelegramThread || !status.isOpen;
                }

                if (humanSendBtn) {
                    humanSendBtn.disabled = !status.isTelegramThread || !status.isOpen;
                }

                syncOrderAssistButtonState(
                    status.isTelegramThread,
                    status.isTelegramThread
                        ? 'Abrir pedido assistido para este cliente'
                        : 'Pedido assistido disponivel apenas para conversas Telegram');
            }

            async function postForm(endpoint, payload) {
                const body = new URLSearchParams(payload);
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                    body: body.toString()
                });

                let parsed = null;
                try {
                    parsed = await response.json();
                } catch {
                    parsed = null;
                }

                return { ok: response.ok, payload: parsed, status: response.status };
            }

            async function fetchJson(endpoint, query) {
                const queryString = query instanceof URLSearchParams ? query.toString() : new URLSearchParams(query ?? {}).toString();
                const response = await fetch(queryString ? `${endpoint}?${queryString}` : endpoint, {
                    method: 'GET',
                    headers: { 'Accept': 'application/json' },
                    cache: 'no-store'
                });

                let parsed = null;
                try {
                    parsed = await response.json();
                } catch {
                    parsed = null;
                }

                return { ok: response.ok, payload: parsed, status: response.status };
            }

            async function postJson(endpoint, payload) {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json; charset=UTF-8',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(payload ?? {})
                });

                let parsed = null;
                try {
                    parsed = await response.json();
                } catch {
                    parsed = null;
                }

                return { ok: response.ok, payload: parsed, status: response.status };
            }

            function setOrderWizardAlert(text, isError) {
                if (!orderWizardAlert) {
                    return;
                }

                orderWizardAlert.textContent = text ?? '';
                orderWizardAlert.className = isError
                    ? 'alert alert-danger'
                    : 'alert alert-info';
                orderWizardAlert.classList.toggle('d-none', !text);
            }

            function setOrderWizardStatus(text, isError) {
                if (!orderWizardStatus) {
                    return;
                }

                orderWizardStatus.textContent = text ?? '';
                orderWizardStatus.className = isError ? 'text-danger' : 'text-muted';
            }

            function formatPhonePreview(value) {
                return (value ?? '').toString().trim();
            }

            function buildOrderAddressPreview() {
                const safeCep = (orderCep?.value ?? '').trim();
                const parts = [];
                const firstLine = [orderStreet?.value, orderNumber?.value, orderComplement?.value]
                    .map(value => (value ?? '').toString().trim())
                    .filter(value => value);

                if (firstLine.length > 0) {
                    parts.push(firstLine.join(', '));
                }

                const neighborhood = (orderNeighborhood?.value ?? '').trim();
                if (neighborhood) {
                    parts.push(neighborhood);
                }

                const city = (orderCity?.value ?? '').trim();
                const state = (orderState?.value ?? '').trim().toUpperCase();
                const cityUf = [city, state].filter(value => value).join(' - ');
                if (cityUf) {
                    parts.push(cityUf);
                }

                if (safeCep) {
                    parts.push(`CEP ${safeCep}`);
                }

                return parts.length > 0 ? parts.join(', ') : 'Resolva o CEP para montar o endereco.';
            }

            function renderOrderAddressPreview() {
                if (orderAddressPreview) {
                    orderAddressPreview.textContent = buildOrderAddressPreview();
                }
            }

            function getSelectedScheduleMode() {
                return document.querySelector('input[name="orderScheduleMode"]:checked')?.value ?? 'TOD';
            }

            function normalizeCepInput() {
                if (!orderCep) {
                    return '';
                }

                const digits = (orderCep.value ?? '').replace(/\D/g, '').slice(0, 8);
                orderCep.value = digits.length > 5
                    ? `${digits.slice(0, 5)}-${digits.slice(5)}`
                    : digits;
                return digits;
            }

            function updateScheduleControls() {
                if (!orderScheduledAt) {
                    return;
                }

                const scheduleMode = getSelectedScheduleMode();
                orderScheduledAt.disabled = scheduleMode !== 'CAL';
            }

            function populateSelectOptions(selectElement, items, valueSelector, labelSelector, selectedValue) {
                if (!selectElement) {
                    return;
                }

                const safeItems = Array.isArray(items) ? items : [];
                selectElement.innerHTML = safeItems.map(item => {
                    const value = valueSelector(item);
                    const label = labelSelector(item);
                    const selected = value === selectedValue ? ' selected' : '';
                    return `<option value="${escapeHtml(value)}"${selected}>${escapeHtml(label)}</option>`;
                }).join('');
            }

            function resetOrderWizardForm() {
                orderWizardStepIndex = 0;
                setOrderWizardAlert('', false);
                setOrderWizardStatus('', false);

                if (orderDescription) {
                    orderDescription.value = '';
                }

                if (orderCep) {
                    orderCep.value = '';
                }

                if (orderStreet) {
                    orderStreet.value = '';
                }

                if (orderNumber) {
                    orderNumber.value = '';
                }

                if (orderComplement) {
                    orderComplement.value = '';
                }

                if (orderNeighborhood) {
                    orderNeighborhood.value = '';
                }

                if (orderCity) {
                    orderCity.value = '';
                }

                if (orderState) {
                    orderState.value = '';
                }

                if (orderAddressConfirmed) {
                    orderAddressConfirmed.checked = false;
                }

                if (orderScheduledAt) {
                    orderScheduledAt.value = '';
                }

                const todayRadio = document.getElementById('orderScheduleToday');
                if (todayRadio) {
                    todayRadio.checked = true;
                }

                if (orderContactName) {
                    orderContactName.value = '';
                }

                if (orderContactPhone) {
                    orderContactPhone.value = '';
                }

                renderOrderAddressPreview();
                updateScheduleControls();
                renderOrderWizardStep();
            }

            function getOrderContextEligibilityError(context) {
                if (!context?.isTelegramThread) {
                    return 'Pedido assistido disponivel apenas para conversas Telegram.';
                }

                if (!context?.userExists) {
                    return 'Usuario desta conversa ainda nao existe no cadastro do bot.';
                }

                if (!context?.isClientEligible) {
                    return 'Esta conversa pertence a um prestador. Pedido assistido so pode ser aberto para clientes.';
                }

                if (!context?.isRegistrationComplete) {
                    return 'O cliente ainda nao concluiu o cadastro obrigatorio. Finalize o cadastro antes de abrir um pedido assistido.';
                }

                return '';
            }

            function applyOrderBootstrap(payload) {
                const context = payload?.context ?? {};
                orderWizardBootstrap = {
                    context,
                    categories: Array.isArray(payload?.categories) ? payload.categories : [],
                    preferences: Array.isArray(payload?.preferences) ? payload.preferences : []
                };

                populateSelectOptions(
                    orderCategory,
                    orderWizardBootstrap.categories,
                    item => item?.name ?? '',
                    item => item?.name ?? '',
                    orderWizardBootstrap.categories[0]?.name ?? '');

                populateSelectOptions(
                    orderPreference,
                    orderWizardBootstrap.preferences,
                    item => item?.code ?? '',
                    item => item?.label ?? '',
                    'RAT');

                if (orderContactName) {
                    orderContactName.value = context.clientName ?? '';
                }

                if (orderContactPhone) {
                    orderContactPhone.value = context.contactPhone ?? '';
                }

                if (orderCep) {
                    orderCep.value = context.cep ?? '';
                }

                if (orderStreet) {
                    orderStreet.value = context.street ?? '';
                }

                if (orderNumber) {
                    orderNumber.value = context.number ?? '';
                }

                if (orderComplement) {
                    orderComplement.value = context.complement ?? '';
                }

                if (orderNeighborhood) {
                    orderNeighborhood.value = context.neighborhood ?? '';
                }

                if (orderCity) {
                    orderCity.value = context.city ?? '';
                }

                if (orderState) {
                    orderState.value = context.state ?? '';
                }

                renderOrderAddressPreview();
            }

            function renderOrderWizardStep() {
                orderWizardSteps.forEach((step, index) => {
                    step.classList.toggle('active', index === orderWizardStepIndex);
                });

                orderWizardProgressBadges.forEach((badge, index) => {
                    badge.className = index <= orderWizardStepIndex
                        ? 'badge text-bg-primary wizard-progress-badge'
                        : 'badge text-bg-secondary wizard-progress-badge';
                });

                if (orderWizardPrevBtn) {
                    orderWizardPrevBtn.disabled = orderWizardBusy || orderWizardStepIndex === 0;
                }

                if (orderWizardNextBtn) {
                    orderWizardNextBtn.disabled = orderWizardBusy || orderWizardStepIndex >= orderWizardSteps.length - 1;
                    orderWizardNextBtn.classList.toggle('d-none', orderWizardStepIndex >= orderWizardSteps.length - 1);
                }

                if (orderWizardSubmitBtn) {
                    orderWizardSubmitBtn.disabled = orderWizardBusy;
                    orderWizardSubmitBtn.classList.toggle('d-none', orderWizardStepIndex !== orderWizardSteps.length - 1);
                }

                if (orderWizardStepIndex === orderWizardSteps.length - 1) {
                    renderOrderSummary();
                }
            }

            function validateOrderWizardStep(stepIndex) {
                switch (stepIndex) {
                    case 0:
                        if (!(orderCategory?.value ?? '').trim()) {
                            setOrderWizardAlert('Selecione a categoria do servico.', true);
                            return false;
                        }

                        if (!(orderDescription?.value ?? '').trim()) {
                            setOrderWizardAlert('Informe a descricao do pedido.', true);
                            return false;
                        }

                        break;

                    case 1:
                        normalizeCepInput();
                        if ((orderCep?.value ?? '').replace(/\D/g, '').length !== 8
                            || !(orderStreet?.value ?? '').trim()
                            || !(orderNumber?.value ?? '').trim()
                            || !(orderNeighborhood?.value ?? '').trim()
                            || !(orderCity?.value ?? '').trim()
                            || !(orderState?.value ?? '').trim()) {
                            setOrderWizardAlert('Preencha o endereco completo e resolva um CEP valido.', true);
                            return false;
                        }

                        if (!orderAddressConfirmed?.checked) {
                            setOrderWizardAlert('Confirme os dados do endereco antes de continuar.', true);
                            return false;
                        }

                        break;

                    case 2:
                        if (getSelectedScheduleMode() === 'CAL' && !(orderScheduledAt?.value ?? '').trim()) {
                            setOrderWizardAlert('Informe a data e hora do agendamento.', true);
                            return false;
                        }

                        break;

                    case 3:
                        if (!(orderPreference?.value ?? '').trim()) {
                            setOrderWizardAlert('Selecione a preferencia de distribuicao.', true);
                            return false;
                        }

                        break;

                    case 4:
                        if (!(orderContactName?.value ?? '').trim() || !(orderContactPhone?.value ?? '').trim()) {
                            setOrderWizardAlert('Informe nome e telefone do contato.', true);
                            return false;
                        }

                        break;
                }

                setOrderWizardAlert('', false);
                return true;
            }

            function buildOrderSummaryText() {
                const scheduleMode = getSelectedScheduleMode();
                const whenText = scheduleMode === 'URG'
                    ? 'Urgente'
                    : scheduleMode === 'TOD'
                        ? 'Hoje no proximo horario'
                        : (() => {
                            const raw = (orderScheduledAt?.value ?? '').trim();
                            if (!raw) {
                                return 'Agendar';
                            }

                            const parsed = new Date(raw);
                            return Number.isNaN(parsed.getTime())
                                ? raw
                                : parsed.toLocaleString('pt-BR', {
                                    day: '2-digit',
                                    month: '2-digit',
                                    year: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit'
                                });
                        })();

                const preferenceLabel = orderPreference?.selectedOptions?.[0]?.textContent?.trim() ?? '';
                return [
                    `Categoria: ${(orderCategory?.value ?? '').trim()}`,
                    `Descricao: ${(orderDescription?.value ?? '').trim()}`,
                    `Contato: ${(orderContactName?.value ?? '').trim()}`,
                    `Telefone contato: ${formatPhonePreview(orderContactPhone?.value)}`,
                    `Endereco: ${buildOrderAddressPreview()}`,
                    `Quando: ${whenText}`,
                    `Preferencia: ${preferenceLabel}`
                ].join('\n');
            }

            function renderOrderSummary() {
                if (orderSummaryBox) {
                    orderSummaryBox.textContent = buildOrderSummaryText();
                }
            }

            function setOrderWizardBusyState(isBusy, statusText) {
                orderWizardBusy = isBusy;
                setOrderWizardStatus(statusText ?? '', false);

                if (orderAssistBtn) {
                    orderAssistBtn.disabled = isBusy;
                }

                if (orderResolveCepBtn) {
                    orderResolveCepBtn.disabled = isBusy;
                }

                renderOrderWizardStep();
            }

            function syncOrderAssistButtonState(isTelegramThread, titleText) {
                if (!orderAssistBtn) {
                    return;
                }

                orderAssistBtn.disabled = !isTelegramThread || orderWizardBusy;
                orderAssistBtn.title = titleText ?? '';
            }

            async function openAssistedOrderWizard() {
                if (!assistOrderModal) {
                    setHumanSendStatus('Bootstrap Modal indisponivel nesta tela.', true);
                    return;
                }

                setOrderWizardBusyState(true, 'Carregando dados do cliente...');
                resetOrderWizardForm();

                const result = await fetchJson(orderWizardBootstrapEndpoint, {
                    tenant: tenantId,
                    phone
                });

                if (!result.ok) {
                    setOrderWizardBusyState(false, '');
                    setHumanSendStatus(result.payload?.error ?? `Falha HTTP ${result.status} ao carregar o pedido assistido.`, true);
                    return;
                }

                applyOrderBootstrap(result.payload);
                const eligibilityError = getOrderContextEligibilityError(orderWizardBootstrap?.context);
                if (eligibilityError) {
                    setOrderWizardBusyState(false, '');
                    setHumanSendStatus(eligibilityError, true);
                    return;
                }

                setOrderWizardBusyState(false, '');
                assistOrderModal.show();
            }

            async function resolveCepForOrderWizard() {
                const digits = normalizeCepInput();
                if (digits.length !== 8) {
                    setOrderWizardAlert('Informe um CEP valido com 8 digitos.', true);
                    return;
                }

                setOrderWizardBusyState(true, 'Consultando CEP...');
                const result = await fetchJson(orderResolveCepEndpoint, { cep: digits });
                setOrderWizardBusyState(false, '');

                if (!result.ok) {
                    setOrderWizardAlert(result.payload?.error ?? `Falha HTTP ${result.status} ao consultar o CEP.`, true);
                    return;
                }

                const payload = result.payload ?? {};
                if (orderCep) {
                    orderCep.value = payload.cep ?? orderCep.value;
                }

                if (orderStreet) {
                    orderStreet.value = payload.street ?? '';
                }

                if (orderNeighborhood) {
                    orderNeighborhood.value = payload.neighborhood ?? '';
                }

                if (orderCity) {
                    orderCity.value = payload.city ?? '';
                }

                if (orderState) {
                    orderState.value = (payload.state ?? '').toString().toUpperCase();
                }

                orderWizardBootstrap = orderWizardBootstrap ?? {};
                orderWizardBootstrap.latitude = payload.latitude ?? null;
                orderWizardBootstrap.longitude = payload.longitude ?? null;

                renderOrderAddressPreview();
                setOrderWizardAlert(payload.geocodeOk === false
                    ? 'Endereco resolvido. O geocode nao retornou coordenadas agora, mas o pedido pode seguir mesmo assim.'
                    : '', !payload.geocodeOk);
            }

            async function submitAssistedOrder() {
                for (let stepIndex = 0; stepIndex < orderWizardSteps.length - 1; stepIndex += 1) {
                    if (!validateOrderWizardStep(stepIndex)) {
                        orderWizardStepIndex = stepIndex;
                        renderOrderWizardStep();
                        return;
                    }
                }

                const payload = {
                    tenantId,
                    phone,
                    category: (orderCategory?.value ?? '').trim(),
                    description: (orderDescription?.value ?? '').trim(),
                    cep: (orderCep?.value ?? '').trim(),
                    street: (orderStreet?.value ?? '').trim(),
                    number: (orderNumber?.value ?? '').trim(),
                    complement: (orderComplement?.value ?? '').trim(),
                    neighborhood: (orderNeighborhood?.value ?? '').trim(),
                    city: (orderCity?.value ?? '').trim(),
                    state: (orderState?.value ?? '').trim().toUpperCase(),
                    latitude: orderWizardBootstrap?.latitude ?? orderWizardBootstrap?.context?.latitude ?? orderWizardBootstrap?.context?.Latitude ?? null,
                    longitude: orderWizardBootstrap?.longitude ?? orderWizardBootstrap?.context?.longitude ?? orderWizardBootstrap?.context?.Longitude ?? null,
                    scheduleMode: getSelectedScheduleMode(),
                    scheduledAtLocal: (orderScheduledAt?.value ?? '').trim(),
                    preferenceCode: (orderPreference?.value ?? '').trim(),
                    contactName: (orderContactName?.value ?? '').trim(),
                    contactPhone: (orderContactPhone?.value ?? '').trim()
                };

                setOrderWizardBusyState(true, 'Enviando confirmacao para o cliente...');
                const result = await postJson(createAssistedOrderEndpoint, payload);
                setOrderWizardBusyState(false, '');

                if (!result.ok) {
                    setOrderWizardAlert(result.payload?.error ?? `Falha HTTP ${result.status} ao enviar a confirmacao.`, true);
                    const fallbackHandoff = normalizeHandoff(result.payload?.handoff);
                    renderHandoff(fallbackHandoff);
                    lastHandoffSignature = buildHandoffSignature(fallbackHandoff);
                    return;
                }

                const updatedStatus = normalizeHandoff(result.payload?.handoff);
                renderHandoff(updatedStatus);
                lastHandoffSignature = buildHandoffSignature(updatedStatus);
                assistOrderModal.hide();
                setHumanSendStatus('Pedido assistido enviado para confirmacao do cliente.', false);
                await refreshConversation('pedido assistido');
            }

            function updateRealtimeStatus(text, enabled) {
                if (!realtimeStatusBadge) {
                    return;
                }

                realtimeStatusBadge.textContent = text;
                realtimeStatusBadge.className = enabled
                    ? 'badge text-bg-success'
                    : 'badge text-bg-secondary';
            }

            function updateUpdatedAt(reason) {
                if (!realtimeUpdatedAt) {
                    return;
                }

                const clock = new Date().toLocaleTimeString('pt-BR');
                realtimeUpdatedAt.textContent = `Ultima atualizacao: ${clock}${reason ? ` (${reason})` : ''}`;
            }

            function updateToggleButton() {
                if (!realtimeToggleBtn) {
                    return;
                }

                realtimeToggleBtn.textContent = realtimeEnabled ? 'Desligar realtime' : 'Ligar realtime';
                realtimeToggleBtn.className = realtimeEnabled
                    ? 'btn btn-sm btn-outline-danger realtime-toggle-btn'
                    : 'btn btn-sm btn-outline-primary realtime-toggle-btn';
            }

            function isNearBottom() {
                if (!chatTrack) {
                    return true;
                }

                const delta = chatTrack.scrollHeight - chatTrack.scrollTop - chatTrack.clientHeight;
                return delta <= 80;
            }

            function scrollToBottom() {
                if (!chatTrack) {
                    return;
                }

                chatTrack.scrollTop = chatTrack.scrollHeight;
            }

            function renderMessages(messages, forceScroll) {
                if (!chatRows) {
                    return;
                }

                if (!Array.isArray(messages) || messages.length === 0) {
                    chatRows.innerHTML = '<div class="chat-empty">Sem mensagens visiveis para esta conversa.</div>';
                    if (forceScroll) {
                        scrollToBottom();
                    }
                    return;
                }

                const shouldScroll = forceScroll || isNearBottom();
                const html = messages.map(message => {
                    const inbound = isInboundDirection(message.direction);
                    const rowClass = inbound ? 'chat-left' : 'chat-right';
                    const bubbleClass = inbound ? 'chat-bubble-in' : 'chat-bubble-out';
                    const role = (message.role ?? '').toString().trim() || '-';
                    const roleLower = role.toLowerCase();
                    const sender = inbound
                        ? 'Cliente'
                        : roleLower === 'human'
                            ? 'Atendente'
                            : 'Bot';
                    const hasDeliveryStatus = !inbound && String(message.deliveryStatus ?? '').trim().length > 0;
                    const deliveryHtml = hasDeliveryStatus
                        ? `
                            <div class="chat-delivery">
                                <span class="badge ${deliveryStatusBadgeClass(message.deliveryStatus)}">${escapeHtml(deliveryStatusLabel(message.deliveryStatus))}</span>
                                ${message.deliveryStatusAtUtc ? `<span>${escapeHtml(formatDateTime(message.deliveryStatusAtUtc))}</span>` : ''}
                            </div>
                            ${message.deliveryError ? `<div class="chat-delivery-error">${escapeHtml(message.deliveryError)}</div>` : ''}
                        `
                        : '';

                    return `
                        <div class="chat-row ${rowClass}">
                            <div class="chat-bubble ${bubbleClass}">
                                <div class="chat-meta">
                                    <span class="badge ${toRoleBadgeClass(role)}">${escapeHtml(role)}</span>
                                    <span class="chat-sender">${sender}</span>
                                    <span>${escapeHtml(formatDateTime(message.createdAtUtc))}</span>
                                </div>
                                <p class="chat-content">${escapeHtml(message.content)}</p>
                                ${deliveryHtml}
                            </div>
                        </div>
                    `;
                });

                chatRows.innerHTML = html.join('');

                if (shouldScroll) {
                    scrollToBottom();
                }
            }

            async function refreshConversation(reason) {
                if (isRefreshing) {
                    return;
                }

                isRefreshing = true;
                try {
                    const query = new URLSearchParams({
                        tenant: tenantId,
                        phone,
                        limit: String(snapshotLimit)
                    });

                    const response = await fetch(`${snapshotEndpoint}?${query.toString()}`, {
                        method: 'GET',
                        headers: { 'Accept': 'application/json' },
                        cache: 'no-store'
                    });

                    if (!response.ok) {
                        updateRealtimeStatus(`Falha HTTP ${response.status}`, false);
                        return;
                    }

                    const payload = await response.json();
                    const messages = normalizeMessages(payload.messages ?? payload.Messages ?? []);
                    const handoff = normalizeHandoff(payload.handoff ?? payload.Handoff ?? currentHandoff);
                    const signature = buildSignature(messages);
                    const handoffSignature = buildHandoffSignature(handoff);

                    if (signature !== lastSignature) {
                        renderMessages(messages, false);
                        lastSignature = signature;
                    }

                    if (handoffSignature !== lastHandoffSignature) {
                        renderHandoff(handoff);
                        lastHandoffSignature = handoffSignature;
                    }

                    updateUpdatedAt(reason ?? 'sync');
                    if (realtimeEnabled) {
                        updateRealtimeStatus('Realtime ligado', true);
                    }
                } catch {
                    updateRealtimeStatus('Erro de atualizacao', false);
                } finally {
                    isRefreshing = false;
                }
            }

            function createConnection() {
                if (!window.signalR) {
                    updateRealtimeStatus('SignalR indisponivel', false);
                    return null;
                }

                const connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/dashboard')
                    .withAutomaticReconnect([0, 2000, 5000, 10000])
                    .build();

                connection.on('dashboardChanged', async payload => {
                    if (!realtimeEnabled) {
                        return;
                    }

                    const eventTenantId = (payload?.tenantId ?? payload?.TenantId ?? '').toString().trim();
                    if (eventTenantId && eventTenantId.toLowerCase() !== tenantId.toLowerCase()) {
                        return;
                    }

                    await refreshConversation('tempo real');
                });

                connection.onreconnecting(() => {
                    if (realtimeEnabled) {
                        updateRealtimeStatus('Realtime reconectando', false);
                    }
                });

                connection.onreconnected(async () => {
                    if (!realtimeEnabled) {
                        return;
                    }

                    try {
                        await connection.invoke('JoinTenant', tenantId);
                    } catch {
                        // ignore
                    }

                    updateRealtimeStatus('Realtime ligado', true);
                    await refreshConversation('reconectado');
                });

                connection.onclose(() => {
                    if (realtimeEnabled) {
                        updateRealtimeStatus('Realtime desconectado', false);
                    }
                });

                return connection;
            }

            async function startRealtime() {
                realtimeEnabled = true;
                updateToggleButton();
                saveRealtimePreference(true);

                if (!realtimeConnection) {
                    realtimeConnection = createConnection();
                }

                if (!realtimeConnection) {
                    updateRealtimeStatus('SignalR indisponivel', false);
                    return;
                }

                try {
                    if (realtimeConnection.state !== signalR.HubConnectionState.Connected) {
                        await realtimeConnection.start();
                    }

                    await realtimeConnection.invoke('JoinTenant', tenantId);
                    updateRealtimeStatus('Realtime ligado', true);
                    await refreshConversation('conectado');
                } catch {
                    updateRealtimeStatus('Falha na conexao realtime', false);
                }
            }

            async function stopRealtime() {
                realtimeEnabled = false;
                updateToggleButton();
                saveRealtimePreference(false);

                if (!realtimeConnection) {
                    updateRealtimeStatus('Realtime desligado', false);
                    return;
                }

                try {
                    if (realtimeConnection.state === signalR.HubConnectionState.Connected) {
                        await realtimeConnection.invoke('LeaveTenant', tenantId);
                    }
                } catch {
                    // ignore
                }

                try {
                    await realtimeConnection.stop();
                } catch {
                    // ignore
                }

                realtimeConnection = null;
                updateRealtimeStatus('Realtime desligado', false);
            }

            if (handoffOpenBtn) {
                handoffOpenBtn.addEventListener('click', async () => {
                    setHumanSendStatus('Abrindo atendimento humano...', false);
                    const result = await postForm(handoffOpenEndpoint, {
                        tenant: tenantId,
                        phone
                    });

                    if (!result.ok) {
                        setHumanSendStatus(result.payload?.error ?? `Falha HTTP ${result.status} ao abrir atendimento.`, true);
                        return;
                    }

                    const status = normalizeHandoff(result.payload?.handoff);
                    renderHandoff(status);
                    lastHandoffSignature = buildHandoffSignature(status);
                    setHumanSendStatus('Atendimento humano iniciado.', false);
                    await refreshConversation('handoff aberto');
                });
            }

            if (handoffCloseBtn) {
                handoffCloseBtn.addEventListener('click', async () => {
                    setHumanSendStatus('Encerrando atendimento humano...', false);
                    const result = await postForm(handoffCloseEndpoint, {
                        tenant: tenantId,
                        phone
                    });

                    if (!result.ok) {
                        setHumanSendStatus(result.payload?.error ?? `Falha HTTP ${result.status} ao encerrar atendimento.`, true);
                        return;
                    }

                    const status = normalizeHandoff(result.payload?.handoff);
                    renderHandoff(status);
                    lastHandoffSignature = buildHandoffSignature(status);
                    setHumanSendStatus('Atendimento humano encerrado.', false);
                    await refreshConversation('handoff fechado');
                });
            }

            if (humanSendBtn) {
                humanSendBtn.addEventListener('click', async () => {
                    const message = (humanMessageInput?.value ?? '').trim();
                    if (!message) {
                        setHumanSendStatus('Digite uma mensagem antes de enviar.', true);
                        return;
                    }

                    if (!currentHandoff.isTelegramThread) {
                        setHumanSendStatus('Intervencao humana disponivel apenas para conversas Telegram.', true);
                        return;
                    }

                    if (!currentHandoff.isOpen) {
                        setHumanSendStatus('Abra o atendimento humano antes de enviar mensagens.', true);
                        return;
                    }

                    humanSendBtn.disabled = true;
                    setHumanSendStatus('Enviando mensagem...', false);
                    const result = await postForm(sendHumanEndpoint, {
                        tenant: tenantId,
                        phone,
                        message
                    });
                    humanSendBtn.disabled = false;

                    if (!result.ok) {
                        setHumanSendStatus(result.payload?.error ?? `Falha HTTP ${result.status} no envio.`, true);
                        const fallbackStatus = normalizeHandoff(result.payload?.handoff);
                        renderHandoff(fallbackStatus);
                        lastHandoffSignature = buildHandoffSignature(fallbackStatus);
                        return;
                    }

                    if (humanMessageInput) {
                        humanMessageInput.value = '';
                    }

                    const updatedStatus = normalizeHandoff(result.payload?.handoff);
                    renderHandoff(updatedStatus);
                    lastHandoffSignature = buildHandoffSignature(updatedStatus);
                    setHumanSendStatus('Mensagem enviada com sucesso.', false);
                    await refreshConversation('envio humano');
                });
            }

            if (orderAssistBtn) {
                orderAssistBtn.addEventListener('click', async () => {
                    await openAssistedOrderWizard();
                });
            }

            if (orderResolveCepBtn) {
                orderResolveCepBtn.addEventListener('click', async () => {
                    await resolveCepForOrderWizard();
                });
            }

            if (orderWizardPrevBtn) {
                orderWizardPrevBtn.addEventListener('click', () => {
                    if (orderWizardStepIndex > 0) {
                        orderWizardStepIndex -= 1;
                        setOrderWizardAlert('', false);
                        renderOrderWizardStep();
                    }
                });
            }

            if (orderWizardNextBtn) {
                orderWizardNextBtn.addEventListener('click', () => {
                    if (!validateOrderWizardStep(orderWizardStepIndex)) {
                        return;
                    }

                    if (orderWizardStepIndex < orderWizardSteps.length - 1) {
                        orderWizardStepIndex += 1;
                        renderOrderWizardStep();
                    }
                });
            }

            if (orderWizardSubmitBtn) {
                orderWizardSubmitBtn.addEventListener('click', async () => {
                    await submitAssistedOrder();
                });
            }

            document.querySelectorAll('input[name="orderScheduleMode"]').forEach(element => {
                element.addEventListener('change', () => {
                    updateScheduleControls();
                    renderOrderSummary();
                });
            });

            [orderCep, orderStreet, orderNumber, orderComplement, orderNeighborhood, orderCity, orderState].forEach(element => {
                if (!element) {
                    return;
                }

                element.addEventListener('input', () => {
                    renderOrderAddressPreview();
                });
            });

            [orderCategory, orderDescription, orderScheduledAt, orderPreference, orderContactName, orderContactPhone].forEach(element => {
                if (!element) {
                    return;
                }

                element.addEventListener('input', () => {
                    renderOrderSummary();
                });
                element.addEventListener('change', () => {
                    renderOrderSummary();
                });
            });

            if (assistOrderModalElement) {
                assistOrderModalElement.addEventListener('hidden.bs.modal', () => {
                    setOrderWizardAlert('', false);
                    setOrderWizardStatus('', false);
                });
            }

            if (realtimeToggleBtn) {
                realtimeToggleBtn.addEventListener('click', async () => {
                    if (realtimeEnabled) {
                        await stopRealtime();
                    } else {
                        await startRealtime();
                    }
                });
            }

            const normalizedInitial = normalizeMessages(initialMessages);
            lastSignature = buildSignature(normalizedInitial);
            lastHandoffSignature = buildHandoffSignature(initialHandoff);
            renderMessages(normalizedInitial, true);
            renderHandoff(initialHandoff);
            resetOrderWizardForm();
            setHumanSendStatus('', false);
            updateUpdatedAt('carregado');
            updateToggleButton();

            if (realtimeEnabled) {
                startRealtime();
            } else {
                updateRealtimeStatus('Realtime desligado', false);
            }

            window.addEventListener('beforeunload', () => {
                if (realtimeConnection) {
                    realtimeConnection.invoke('LeaveTenant', tenantId).catch(() => {
                        // ignore
                    });
                    realtimeConnection.stop().catch(() => {
                        // ignore
                    });
                }
            });
        })();
    </script>
}
