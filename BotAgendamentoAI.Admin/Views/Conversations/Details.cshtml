@model BotAgendamentoAI.Admin.Models.ConversationDetailsViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Detalhes da conversa";
    var visibleMessages = Model.Messages
        .Where(message => !string.Equals(message.Role, "tool", StringComparison.OrdinalIgnoreCase))
        .ToList();
    var realtimeLimit = (int?)ViewData["Limit"] ?? 250;
    var initialHandoff = Model.Handoff ?? new BotAgendamentoAI.Admin.Models.ConversationHandoffStatus
    {
        TenantId = Model.TenantId,
        Phone = Model.Phone
    };
}

<style>
    .conversation-chat-card {
        border: 1px solid #dce5eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .conversation-chat-track {
        max-height: 72vh;
        overflow-y: auto;
        padding: 1rem;
        background:
            radial-gradient(circle at 1px 1px, rgba(35, 42, 54, 0.06) 1px, transparent 0) 0 0/16px 16px,
            linear-gradient(180deg, #eef4f8 0%, #e7eef3 100%);
    }

    .chat-row {
        display: flex;
        margin-bottom: 0.65rem;
    }

    .chat-left {
        justify-content: flex-start;
    }

    .chat-right {
        justify-content: flex-end;
    }

    .chat-bubble {
        max-width: min(78%, 820px);
        border-radius: 12px;
        padding: 0.5rem 0.7rem;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .chat-bubble-in {
        background: #ffffff;
        border-top-left-radius: 4px;
    }

    .chat-bubble-out {
        background: #dcf8c6;
        border-top-right-radius: 4px;
    }

    .chat-meta {
        display: flex;
        gap: 0.4rem;
        align-items: center;
        margin-bottom: 0.35rem;
        font-size: 0.75rem;
        color: #556170;
    }

    .chat-sender {
        color: #000000;
        font-weight: 700;
    }

    .chat-content {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
        font-size: 0.92rem;
        color: #1f2a33;
    }

    .chat-empty {
        text-align: center;
        color: #6b7785;
        padding: 2rem 1rem;
    }

    .realtime-toggle-btn {
        min-width: 150px;
    }

    .handoff-status-card {
        border: 1px solid #dce5eb;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 m-0">Conversa @Model.Phone</h1>
    <div class="d-flex gap-2 align-items-center">
        <span id="realtimeStatusBadge" class="badge text-bg-secondary">Realtime desligado</span>
        <button id="realtimeToggleBtn" type="button" class="btn btn-sm btn-outline-primary realtime-toggle-btn">Ligar realtime</button>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index" asp-route-tenant="@Model.TenantId">Voltar</a>
    </div>
</div>

<div class="card handoff-status-card mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <div class="text-muted small">Atendimento humano</div>
                <div class="d-flex align-items-center gap-2">
                    <span id="handoffStatusBadge" class="badge text-bg-secondary">Fechado</span>
                    <small id="handoffMeta" class="text-muted">Sem atendimento ativo.</small>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button id="handoffOpenBtn" type="button" class="btn btn-sm btn-outline-success">Iniciar atendimento</button>
                <button id="handoffCloseBtn" type="button" class="btn btn-sm btn-outline-danger">Encerrar atendimento</button>
            </div>
        </div>

        <div id="handoffNotTelegramAlert" class="alert alert-info py-2 px-3 mt-3 mb-0 d-none">
            Intervencao humana disponivel apenas para conversas Telegram (formato tg:&lt;id&gt;).
        </div>

        <div class="mt-3">
            <label class="form-label" for="humanMessageInput">Mensagem do atendente</label>
            <textarea id="humanMessageInput" class="form-control" rows="3" maxlength="1200" placeholder="Digite a mensagem para o cliente ou prestador..."></textarea>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small id="humanSendStatus" class="text-muted"></small>
                <button id="humanSendBtn" type="button" class="btn btn-sm btn-primary">Enviar mensagem</button>
            </div>
        </div>
    </div>
</div>

<div class="card conversation-chat-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Historico</strong>
        <small id="realtimeUpdatedAt" class="text-muted">Ultima atualizacao: carregando...</small>
    </div>
    <div id="chatTrack" class="conversation-chat-track">
        <div id="chatRows">
            @if (visibleMessages.Count == 0)
            {
                <div class="chat-empty">Sem mensagens visiveis para esta conversa.</div>
            }
            else
            {
                @foreach (var message in visibleMessages)
                {
                    var isInbound = string.Equals(message.Direction, "in", StringComparison.OrdinalIgnoreCase);
                    var bubbleClass = isInbound ? "chat-bubble-in" : "chat-bubble-out";
                    var rowClass = isInbound ? "chat-left" : "chat-right";
                    var roleLower = (message.Role ?? string.Empty).Trim().ToLowerInvariant();
                    var roleBadgeClass = roleLower switch
                    {
                        "assistant" => "text-bg-primary",
                        "human" => "text-bg-info",
                        "system" => "text-bg-warning",
                        _ => "text-bg-secondary"
                    };
                    var senderName = isInbound
                        ? "Cliente"
                        : roleLower == "human"
                            ? "Atendente"
                            : "Bot";

                    <div class="chat-row @rowClass">
                        <div class="chat-bubble @bubbleClass">
                            <div class="chat-meta">
                                <span class="badge @roleBadgeClass">@message.Role</span>
                                <span class="chat-sender">@senderName</span>
                                <span>@message.CreatedAtUtc.ToLocalTime().ToString("dd/MM HH:mm:ss")</span>
                            </div>
                            <p class="chat-content">@message.Content</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const tenantId = @Html.Raw(JsonSerializer.Serialize(Model.TenantId));
            const phone = @Html.Raw(JsonSerializer.Serialize(Model.Phone));
            const snapshotLimit = @realtimeLimit;
            const snapshotEndpoint = '@Url.Action("Snapshot", "Conversations")';
            const handoffOpenEndpoint = '@Url.Action("HandoffOpen", "Conversations")';
            const handoffCloseEndpoint = '@Url.Action("HandoffClose", "Conversations")';
            const sendHumanEndpoint = '@Url.Action("SendHumanMessage", "Conversations")';
            const initialMessages = @Html.Raw(JsonSerializer.Serialize(
                visibleMessages.Select(message => new
                {
                    id = message.Id,
                    direction = message.Direction,
                    role = message.Role,
                    content = message.Content,
                    createdAtUtc = message.CreatedAtUtc.ToString("O")
                })));
            const initialHandoff = @Html.Raw(JsonSerializer.Serialize(new
            {
                tenantId = initialHandoff.TenantId,
                phone = initialHandoff.Phone,
                isTelegramThread = initialHandoff.IsTelegramThread,
                isOpen = initialHandoff.IsOpen,
                requestedByRole = initialHandoff.RequestedByRole,
                assignedAgent = initialHandoff.AssignedAgent,
                previousState = initialHandoff.PreviousState,
                closeReason = initialHandoff.CloseReason,
                requestedAtUtc = initialHandoff.RequestedAtUtc?.ToString("O"),
                acceptedAtUtc = initialHandoff.AcceptedAtUtc?.ToString("O"),
                closedAtUtc = initialHandoff.ClosedAtUtc?.ToString("O"),
                lastMessageAtUtc = initialHandoff.LastMessageAtUtc?.ToString("O")
            }));

            const chatTrack = document.getElementById('chatTrack');
            const chatRows = document.getElementById('chatRows');
            const realtimeToggleBtn = document.getElementById('realtimeToggleBtn');
            const realtimeStatusBadge = document.getElementById('realtimeStatusBadge');
            const realtimeUpdatedAt = document.getElementById('realtimeUpdatedAt');
            const handoffStatusBadge = document.getElementById('handoffStatusBadge');
            const handoffMeta = document.getElementById('handoffMeta');
            const handoffOpenBtn = document.getElementById('handoffOpenBtn');
            const handoffCloseBtn = document.getElementById('handoffCloseBtn');
            const handoffNotTelegramAlert = document.getElementById('handoffNotTelegramAlert');
            const humanMessageInput = document.getElementById('humanMessageInput');
            const humanSendBtn = document.getElementById('humanSendBtn');
            const humanSendStatus = document.getElementById('humanSendStatus');
            const storageKey = `conversation-realtime:${tenantId}:${phone}`;

            let realtimeConnection = null;
            let realtimeEnabled = true;
            let isRefreshing = false;
            let lastSignature = '';
            let lastHandoffSignature = '';
            let currentHandoff = normalizeHandoff(initialHandoff);

            try {
                const storedValue = window.localStorage.getItem(storageKey);
                realtimeEnabled = storedValue !== 'off';
            } catch {
                realtimeEnabled = true;
            }

            function saveRealtimePreference(enabled) {
                try {
                    window.localStorage.setItem(storageKey, enabled ? 'on' : 'off');
                } catch {
                    // ignore
                }
            }

            function escapeHtml(value) {
                return (value ?? '')
                    .toString()
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function isInboundDirection(direction) {
                const normalized = (direction ?? '').toString().trim().toLowerCase();
                return normalized === 'in' || normalized === 'inbound' || normalized === 'incoming';
            }

            function toRoleBadgeClass(role) {
                const normalized = (role ?? '').toString().trim().toLowerCase();
                if (normalized === 'assistant') {
                    return 'text-bg-primary';
                }

                if (normalized === 'human') {
                    return 'text-bg-info';
                }

                if (normalized === 'system') {
                    return 'text-bg-warning';
                }

                return 'text-bg-secondary';
            }

            function formatDateTime(value) {
                const parsed = new Date(value ?? '');
                if (Number.isNaN(parsed.getTime())) {
                    return '-';
                }

                return parsed.toLocaleString('pt-BR', {
                    day: '2-digit',
                    month: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit'
                });
            }

            function normalizeMessages(rawItems) {
                if (!Array.isArray(rawItems)) {
                    return [];
                }

                return rawItems
                    .map(raw => ({
                        id: raw.id ?? raw.Id ?? 0,
                        direction: raw.direction ?? raw.Direction ?? '',
                        role: raw.role ?? raw.Role ?? '',
                        content: raw.content ?? raw.Content ?? '',
                        createdAtUtc: raw.createdAtUtc ?? raw.CreatedAtUtc ?? ''
                    }))
                    .filter(item => (item.role ?? '').toString().trim().toLowerCase() !== 'tool');
            }

            function normalizeHandoff(raw) {
                const source = raw ?? {};
                return {
                    tenantId: (source.tenantId ?? source.TenantId ?? tenantId ?? '').toString(),
                    phone: (source.phone ?? source.Phone ?? phone ?? '').toString(),
                    isTelegramThread: !!(source.isTelegramThread ?? source.IsTelegramThread),
                    isOpen: !!(source.isOpen ?? source.IsOpen),
                    requestedByRole: (source.requestedByRole ?? source.RequestedByRole ?? '').toString(),
                    assignedAgent: (source.assignedAgent ?? source.AssignedAgent ?? '').toString(),
                    previousState: (source.previousState ?? source.PreviousState ?? '').toString(),
                    closeReason: (source.closeReason ?? source.CloseReason ?? '').toString(),
                    requestedAtUtc: source.requestedAtUtc ?? source.RequestedAtUtc ?? null,
                    acceptedAtUtc: source.acceptedAtUtc ?? source.AcceptedAtUtc ?? null,
                    closedAtUtc: source.closedAtUtc ?? source.ClosedAtUtc ?? null,
                    lastMessageAtUtc: source.lastMessageAtUtc ?? source.LastMessageAtUtc ?? null
                };
            }

            function buildSignature(messages) {
                if (!Array.isArray(messages) || messages.length === 0) {
                    return '0';
                }

                const last = messages[messages.length - 1];
                return `${messages.length}|${last.id}|${last.createdAtUtc}|${(last.content ?? '').length}|${last.role}`;
            }

            function buildHandoffSignature(handoff) {
                const normalized = normalizeHandoff(handoff);
                return [
                    normalized.isTelegramThread ? '1' : '0',
                    normalized.isOpen ? '1' : '0',
                    normalized.requestedAtUtc ?? '',
                    normalized.acceptedAtUtc ?? '',
                    normalized.closedAtUtc ?? '',
                    normalized.lastMessageAtUtc ?? '',
                    normalized.assignedAgent ?? ''
                ].join('|');
            }

            function setHumanSendStatus(text, isError) {
                if (!humanSendStatus) {
                    return;
                }

                humanSendStatus.textContent = text ?? '';
                humanSendStatus.className = isError ? 'text-danger' : 'text-muted';
            }

            function renderHandoff(rawStatus) {
                const status = normalizeHandoff(rawStatus);
                currentHandoff = status;

                if (handoffStatusBadge) {
                    handoffStatusBadge.textContent = status.isOpen ? 'Atendimento ativo' : 'Atendimento fechado';
                    handoffStatusBadge.className = status.isOpen ? 'badge text-bg-success' : 'badge text-bg-secondary';
                }

                if (handoffMeta) {
                    if (!status.isTelegramThread) {
                        handoffMeta.textContent = 'Conversa fora do canal Telegram.';
                    } else if (status.isOpen) {
                        const assigned = status.assignedAgent ? ` | Atendente: ${status.assignedAgent}` : '';
                        handoffMeta.textContent = `Aberto em ${formatDateTime(status.requestedAtUtc)}${assigned}`;
                    } else {
                        handoffMeta.textContent = status.closedAtUtc
                            ? `Ultimo encerramento: ${formatDateTime(status.closedAtUtc)}.`
                            : 'Sem atendimento ativo.';
                    }
                }

                if (handoffNotTelegramAlert) {
                    handoffNotTelegramAlert.classList.toggle('d-none', status.isTelegramThread);
                }

                if (handoffOpenBtn) {
                    handoffOpenBtn.disabled = !status.isTelegramThread || status.isOpen;
                }

                if (handoffCloseBtn) {
                    handoffCloseBtn.disabled = !status.isTelegramThread || !status.isOpen;
                }

                if (humanMessageInput) {
                    humanMessageInput.disabled = !status.isTelegramThread || !status.isOpen;
                }

                if (humanSendBtn) {
                    humanSendBtn.disabled = !status.isTelegramThread || !status.isOpen;
                }
            }

            async function postForm(endpoint, payload) {
                const body = new URLSearchParams(payload);
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                    body: body.toString()
                });

                let parsed = null;
                try {
                    parsed = await response.json();
                } catch {
                    parsed = null;
                }

                return { ok: response.ok, payload: parsed, status: response.status };
            }

            function updateRealtimeStatus(text, enabled) {
                if (!realtimeStatusBadge) {
                    return;
                }

                realtimeStatusBadge.textContent = text;
                realtimeStatusBadge.className = enabled
                    ? 'badge text-bg-success'
                    : 'badge text-bg-secondary';
            }

            function updateUpdatedAt(reason) {
                if (!realtimeUpdatedAt) {
                    return;
                }

                const clock = new Date().toLocaleTimeString('pt-BR');
                realtimeUpdatedAt.textContent = `Ultima atualizacao: ${clock}${reason ? ` (${reason})` : ''}`;
            }

            function updateToggleButton() {
                if (!realtimeToggleBtn) {
                    return;
                }

                realtimeToggleBtn.textContent = realtimeEnabled ? 'Desligar realtime' : 'Ligar realtime';
                realtimeToggleBtn.className = realtimeEnabled
                    ? 'btn btn-sm btn-outline-danger realtime-toggle-btn'
                    : 'btn btn-sm btn-outline-primary realtime-toggle-btn';
            }

            function isNearBottom() {
                if (!chatTrack) {
                    return true;
                }

                const delta = chatTrack.scrollHeight - chatTrack.scrollTop - chatTrack.clientHeight;
                return delta <= 80;
            }

            function scrollToBottom() {
                if (!chatTrack) {
                    return;
                }

                chatTrack.scrollTop = chatTrack.scrollHeight;
            }

            function renderMessages(messages, forceScroll) {
                if (!chatRows) {
                    return;
                }

                if (!Array.isArray(messages) || messages.length === 0) {
                    chatRows.innerHTML = '<div class="chat-empty">Sem mensagens visiveis para esta conversa.</div>';
                    if (forceScroll) {
                        scrollToBottom();
                    }
                    return;
                }

                const shouldScroll = forceScroll || isNearBottom();
                const html = messages.map(message => {
                    const inbound = isInboundDirection(message.direction);
                    const rowClass = inbound ? 'chat-left' : 'chat-right';
                    const bubbleClass = inbound ? 'chat-bubble-in' : 'chat-bubble-out';
                    const role = (message.role ?? '').toString().trim() || '-';
                    const roleLower = role.toLowerCase();
                    const sender = inbound
                        ? 'Cliente'
                        : roleLower === 'human'
                            ? 'Atendente'
                            : 'Bot';

                    return `
                        <div class="chat-row ${rowClass}">
                            <div class="chat-bubble ${bubbleClass}">
                                <div class="chat-meta">
                                    <span class="badge ${toRoleBadgeClass(role)}">${escapeHtml(role)}</span>
                                    <span class="chat-sender">${sender}</span>
                                    <span>${escapeHtml(formatDateTime(message.createdAtUtc))}</span>
                                </div>
                                <p class="chat-content">${escapeHtml(message.content)}</p>
                            </div>
                        </div>
                    `;
                });

                chatRows.innerHTML = html.join('');

                if (shouldScroll) {
                    scrollToBottom();
                }
            }

            async function refreshConversation(reason) {
                if (isRefreshing) {
                    return;
                }

                isRefreshing = true;
                try {
                    const query = new URLSearchParams({
                        tenant: tenantId,
                        phone,
                        limit: String(snapshotLimit)
                    });

                    const response = await fetch(`${snapshotEndpoint}?${query.toString()}`, {
                        method: 'GET',
                        headers: { 'Accept': 'application/json' },
                        cache: 'no-store'
                    });

                    if (!response.ok) {
                        updateRealtimeStatus(`Falha HTTP ${response.status}`, false);
                        return;
                    }

                    const payload = await response.json();
                    const messages = normalizeMessages(payload.messages ?? payload.Messages ?? []);
                    const handoff = normalizeHandoff(payload.handoff ?? payload.Handoff ?? currentHandoff);
                    const signature = buildSignature(messages);
                    const handoffSignature = buildHandoffSignature(handoff);

                    if (signature !== lastSignature) {
                        renderMessages(messages, false);
                        lastSignature = signature;
                    }

                    if (handoffSignature !== lastHandoffSignature) {
                        renderHandoff(handoff);
                        lastHandoffSignature = handoffSignature;
                    }

                    updateUpdatedAt(reason ?? 'sync');
                    if (realtimeEnabled) {
                        updateRealtimeStatus('Realtime ligado', true);
                    }
                } catch {
                    updateRealtimeStatus('Erro de atualizacao', false);
                } finally {
                    isRefreshing = false;
                }
            }

            function createConnection() {
                if (!window.signalR) {
                    updateRealtimeStatus('SignalR indisponivel', false);
                    return null;
                }

                const connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/dashboard')
                    .withAutomaticReconnect([0, 2000, 5000, 10000])
                    .build();

                connection.on('dashboardChanged', async payload => {
                    if (!realtimeEnabled) {
                        return;
                    }

                    const eventTenantId = (payload?.tenantId ?? payload?.TenantId ?? '').toString().trim();
                    if (eventTenantId && eventTenantId.toLowerCase() !== tenantId.toLowerCase()) {
                        return;
                    }

                    await refreshConversation('tempo real');
                });

                connection.onreconnecting(() => {
                    if (realtimeEnabled) {
                        updateRealtimeStatus('Realtime reconectando', false);
                    }
                });

                connection.onreconnected(async () => {
                    if (!realtimeEnabled) {
                        return;
                    }

                    try {
                        await connection.invoke('JoinTenant', tenantId);
                    } catch {
                        // ignore
                    }

                    updateRealtimeStatus('Realtime ligado', true);
                    await refreshConversation('reconectado');
                });

                connection.onclose(() => {
                    if (realtimeEnabled) {
                        updateRealtimeStatus('Realtime desconectado', false);
                    }
                });

                return connection;
            }

            async function startRealtime() {
                realtimeEnabled = true;
                updateToggleButton();
                saveRealtimePreference(true);

                if (!realtimeConnection) {
                    realtimeConnection = createConnection();
                }

                if (!realtimeConnection) {
                    updateRealtimeStatus('SignalR indisponivel', false);
                    return;
                }

                try {
                    if (realtimeConnection.state !== signalR.HubConnectionState.Connected) {
                        await realtimeConnection.start();
                    }

                    await realtimeConnection.invoke('JoinTenant', tenantId);
                    updateRealtimeStatus('Realtime ligado', true);
                    await refreshConversation('conectado');
                } catch {
                    updateRealtimeStatus('Falha na conexao realtime', false);
                }
            }

            async function stopRealtime() {
                realtimeEnabled = false;
                updateToggleButton();
                saveRealtimePreference(false);

                if (!realtimeConnection) {
                    updateRealtimeStatus('Realtime desligado', false);
                    return;
                }

                try {
                    if (realtimeConnection.state === signalR.HubConnectionState.Connected) {
                        await realtimeConnection.invoke('LeaveTenant', tenantId);
                    }
                } catch {
                    // ignore
                }

                try {
                    await realtimeConnection.stop();
                } catch {
                    // ignore
                }

                realtimeConnection = null;
                updateRealtimeStatus('Realtime desligado', false);
            }

            if (handoffOpenBtn) {
                handoffOpenBtn.addEventListener('click', async () => {
                    setHumanSendStatus('Abrindo atendimento humano...', false);
                    const result = await postForm(handoffOpenEndpoint, {
                        tenant: tenantId,
                        phone
                    });

                    if (!result.ok) {
                        setHumanSendStatus(result.payload?.error ?? `Falha HTTP ${result.status} ao abrir atendimento.`, true);
                        return;
                    }

                    const status = normalizeHandoff(result.payload?.handoff);
                    renderHandoff(status);
                    lastHandoffSignature = buildHandoffSignature(status);
                    setHumanSendStatus('Atendimento humano iniciado.', false);
                    await refreshConversation('handoff aberto');
                });
            }

            if (handoffCloseBtn) {
                handoffCloseBtn.addEventListener('click', async () => {
                    setHumanSendStatus('Encerrando atendimento humano...', false);
                    const result = await postForm(handoffCloseEndpoint, {
                        tenant: tenantId,
                        phone
                    });

                    if (!result.ok) {
                        setHumanSendStatus(result.payload?.error ?? `Falha HTTP ${result.status} ao encerrar atendimento.`, true);
                        return;
                    }

                    const status = normalizeHandoff(result.payload?.handoff);
                    renderHandoff(status);
                    lastHandoffSignature = buildHandoffSignature(status);
                    setHumanSendStatus('Atendimento humano encerrado.', false);
                    await refreshConversation('handoff fechado');
                });
            }

            if (humanSendBtn) {
                humanSendBtn.addEventListener('click', async () => {
                    const message = (humanMessageInput?.value ?? '').trim();
                    if (!message) {
                        setHumanSendStatus('Digite uma mensagem antes de enviar.', true);
                        return;
                    }

                    if (!currentHandoff.isTelegramThread) {
                        setHumanSendStatus('Intervencao humana disponivel apenas para conversas Telegram.', true);
                        return;
                    }

                    if (!currentHandoff.isOpen) {
                        setHumanSendStatus('Abra o atendimento humano antes de enviar mensagens.', true);
                        return;
                    }

                    humanSendBtn.disabled = true;
                    setHumanSendStatus('Enviando mensagem...', false);
                    const result = await postForm(sendHumanEndpoint, {
                        tenant: tenantId,
                        phone,
                        message
                    });
                    humanSendBtn.disabled = false;

                    if (!result.ok) {
                        setHumanSendStatus(result.payload?.error ?? `Falha HTTP ${result.status} no envio.`, true);
                        const fallbackStatus = normalizeHandoff(result.payload?.handoff);
                        renderHandoff(fallbackStatus);
                        lastHandoffSignature = buildHandoffSignature(fallbackStatus);
                        return;
                    }

                    if (humanMessageInput) {
                        humanMessageInput.value = '';
                    }

                    const updatedStatus = normalizeHandoff(result.payload?.handoff);
                    renderHandoff(updatedStatus);
                    lastHandoffSignature = buildHandoffSignature(updatedStatus);
                    setHumanSendStatus('Mensagem enviada com sucesso.', false);
                    await refreshConversation('envio humano');
                });
            }

            if (realtimeToggleBtn) {
                realtimeToggleBtn.addEventListener('click', async () => {
                    if (realtimeEnabled) {
                        await stopRealtime();
                    } else {
                        await startRealtime();
                    }
                });
            }

            const normalizedInitial = normalizeMessages(initialMessages);
            lastSignature = buildSignature(normalizedInitial);
            lastHandoffSignature = buildHandoffSignature(initialHandoff);
            renderMessages(normalizedInitial, true);
            renderHandoff(initialHandoff);
            setHumanSendStatus('', false);
            updateUpdatedAt('carregado');
            updateToggleButton();

            if (realtimeEnabled) {
                startRealtime();
            } else {
                updateRealtimeStatus('Realtime desligado', false);
            }

            window.addEventListener('beforeunload', () => {
                if (realtimeConnection) {
                    realtimeConnection.invoke('LeaveTenant', tenantId).catch(() => {
                        // ignore
                    });
                    realtimeConnection.stop().catch(() => {
                        // ignore
                    });
                }
            });
        })();
    </script>
}
