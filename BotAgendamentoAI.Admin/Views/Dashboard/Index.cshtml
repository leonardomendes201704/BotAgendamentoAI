@model BotAgendamentoAI.Admin.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}
@using System.Text.Json

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    #bookingsMap {
        height: 440px;
        border-radius: 10px;
    }

    .map-meta {
        font-size: 0.875rem;
        color: #5f6b7a;
    }

    .marker-cluster-small,
    .marker-cluster-medium,
    .marker-cluster-large {
        width: 58px !important;
        height: 58px !important;
        margin-left: -29px !important;
        margin-top: -29px !important;
        border-radius: 50% !important;
        background: rgba(30, 136, 229, 0.35) !important;
        border: 2px solid rgba(13, 71, 161, 0.35) !important;
        box-shadow: 0 0 0 3px rgba(144, 202, 249, 0.28) !important;
    }

    .marker-cluster-small div,
    .marker-cluster-medium div,
    .marker-cluster-large div {
        width: 46px !important;
        height: 46px !important;
        margin-left: 6px !important;
        margin-top: 6px !important;
        line-height: 46px !important;
        border-radius: 50% !important;
        background: rgba(25, 118, 210, 0.95) !important;
        color: #ffffff !important;
        font-size: 18px !important;
        font-weight: 700 !important;
        text-align: center !important;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif !important;
    }

    .kpi-card {
        border: 0;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    .kpi-body {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .kpi-icon {
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 0.7rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        background: rgba(255, 255, 255, 0.22);
        flex-shrink: 0;
    }

    .kpi-label {
        font-size: 0.8rem;
        letter-spacing: 0.01em;
        opacity: 0.9;
        text-transform: uppercase;
    }

    .kpi-value {
        font-size: 1.9rem;
        line-height: 1.1;
        font-weight: 700;
        margin-top: 0.15rem;
    }

    .kpi-blue {
        background: linear-gradient(140deg, #1d4ed8, #2563eb);
        color: #ffffff;
    }

    .kpi-indigo {
        background: linear-gradient(140deg, #4f46e5, #6366f1);
        color: #ffffff;
    }

    .kpi-cyan {
        background: linear-gradient(140deg, #0284c7, #06b6d4);
        color: #ffffff;
    }

    .kpi-green {
        background: linear-gradient(140deg, #059669, #22c55e);
        color: #ffffff;
    }

    .kpi-red {
        background: linear-gradient(140deg, #dc2626, #ef4444);
        color: #ffffff;
    }

    .kpi-violet {
        background: linear-gradient(140deg, #7c3aed, #8b5cf6);
        color: #ffffff;
    }

    .kpi-amber {
        background: linear-gradient(140deg, #d97706, #f59e0b);
        color: #ffffff;
    }

    .kpi-emerald {
        background: linear-gradient(140deg, #0f766e, #14b8a6);
        color: #ffffff;
    }

    .kpi-grid {
        display: grid;
        gap: 0.9rem;
        grid-template-columns: repeat(9, minmax(0, 1fr));
    }

    @@media (max-width: 1200px) {
        .kpi-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 900px) {
        .kpi-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 576px) {
        .kpi-grid {
            grid-template-columns: repeat(1, minmax(0, 1fr));
        }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 m-0">Dashboard</h1>
    <form method="get" class="d-flex gap-2 align-items-center">
        <label class="form-label m-0">Tenant</label>
        <select name="tenant" class="form-select form-select-sm" style="min-width: 140px">
            @foreach (var tenant in Model.Tenants)
            {
                <option value="@tenant" selected="@(tenant == Model.TenantId)">@tenant</option>
            }
        </select>
        <label class="form-label m-0">Dias</label>
        <input type="number" min="1" max="365" name="days" value="@Model.Days" class="form-control form-control-sm" style="width: 90px" />
        <button class="btn btn-sm btn-primary" type="submit">Aplicar</button>
    </form>
</div>

<div class="kpi-grid mb-4">
    <div class="card h-100 kpi-card kpi-blue">
        <div class="card-body kpi-body">
            <span class="kpi-icon"><i class="bi bi-chat-dots-fill"></i></span>
            <div>
                <div class="kpi-label">Conversas ativas</div>
                <div id="metricConversations" class="kpi-value">@Model.TotalIncomingConversations</div>
            </div>
        </div>
    </div>
    <div class="card h-100 kpi-card kpi-indigo">
        <div class="card-body kpi-body">
            <span class="kpi-icon"><i class="bi bi-envelope-fill"></i></span>
            <div>
                <div class="kpi-label">Mensagens</div>
                <div id="metricMessages" class="kpi-value">@Model.TotalMessages</div>
            </div>
        </div>
    </div>
    <div class="card h-100 kpi-card kpi-cyan">
        <div class="card-body kpi-body">
            <span class="kpi-icon"><i class="bi bi-calendar-plus-fill"></i></span>
            <div>
                <div class="kpi-label">Agendamentos em aberto</div>
                <div id="metricBookings" class="kpi-value">@Model.CreatedBookings</div>
            </div>
        </div>
    </div>
    <div class="card h-100 kpi-card kpi-green">
        <div class="card-body kpi-body">
            <span class="kpi-icon"><i class="bi bi-check-circle-fill"></i></span>
            <div>
                <div class="kpi-label">Agendamentos finalizados</div>
                <div id="metricFinishedBookings" class="kpi-value">@Model.FinishedBookings</div>
            </div>
        </div>
    </div>
    <div class="card h-100 kpi-card kpi-red">
        <div class="card-body kpi-body">
            <span class="kpi-icon"><i class="bi bi-x-circle-fill"></i></span>
            <div>
                <div class="kpi-label">Agendamentos cancelados</div>
                <div id="metricCancelledBookings" class="kpi-value">@Model.CancelledBookings</div>
            </div>
        </div>
    </div>
    <div class="card h-100 kpi-card kpi-amber">
        <div class="card-body kpi-body">
            <span class="kpi-icon"><i class="bi bi-hand-thumbs-down-fill"></i></span>
            <div>
                <div class="kpi-label">Pedidos recusados</div>
                <div id="metricRejectedJobs" class="kpi-value">@Model.RejectedJobs</div>
            </div>
        </div>
    </div>
    <div class="card h-100 kpi-card kpi-emerald">
        <div class="card-body kpi-body">
            <span class="kpi-icon"><i class="bi bi-people-fill"></i></span>
            <div>
                <div class="kpi-label">Conversoes</div>
                <div id="metricConvertedPhones" class="kpi-value">@Model.ConvertedPhones</div>
            </div>
        </div>
    </div>
    <div class="card h-100 kpi-card kpi-violet">
        <div class="card-body kpi-body">
            <span class="kpi-icon"><i class="bi bi-graph-up-arrow"></i></span>
            <div>
                <div class="kpi-label">Taxa de conversao</div>
                <div id="metricConversionRate" class="kpi-value">@Model.ConversionRatePercent.ToString("0.##")%</div>
            </div>
        </div>
    </div>
    <div class="card h-100 kpi-card kpi-cyan">
        <div class="card-body kpi-body">
            <span class="kpi-icon"><i class="bi bi-headset"></i></span>
            <div>
                <div class="kpi-label">Atendente humano</div>
                <div id="metricHumanHandoff" class="kpi-value">@Model.HumanHandoffOpen</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Mapa de agendamentos</strong>
        <span id="mapStatus" class="map-meta">Carregando mapa...</span>
    </div>
    <div class="card-body">
        <div id="bookingsMap"></div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Ultimas conversas</strong>
                <a asp-controller="Conversations" asp-action="Index" asp-route-tenant="@Model.TenantId">ver todas</a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover m-0">
                    <thead>
                        <tr>
                            <th>Telefone</th>
                            <th>Ultima msg</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="recentConversationsBody">
                    @foreach (var item in Model.RecentConversations)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Conversations" asp-action="Details" asp-route-tenant="@Model.TenantId" asp-route-phone="@item.Phone">@item.Phone</a>
                            </td>
                            <td>@item.LastMessagePreview</td>
                            <td>
                                @if (item.IsInHumanHandoff)
                                {
                                    <span class="badge bg-warning text-dark">humano</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">bot</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Ultimos agendamentos</strong>
                <a asp-controller="Bookings" asp-action="Index" asp-route-tenant="@Model.TenantId">ver todos</a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover m-0">
                    <thead>
                        <tr>
                            <th>Categoria</th>
                            <th>Servico</th>
                            <th>Telefone</th>
                            <th>Inicio</th>
                        </tr>
                    </thead>
                    <tbody id="recentBookingsBody">
                    @foreach (var item in Model.RecentBookings)
                    {
                        <tr>
                            <td>@item.ServiceCategory</td>
                            <td>@item.ServiceTitle</td>
                            <td>@item.CustomerPhone</td>
                            <td>@item.StartLocal.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
    <script>
        (() => {
            const initialPins = @Html.Raw(JsonSerializer.Serialize(Model.MapPins));
            const tenantId = '@Model.TenantId';
            const days = @Model.Days;
            const snapshotEndpoint = '@Url.Action("Snapshot", "Dashboard")';
            const conversationDetailsUrl = '@Url.Action("Details", "Conversations")';
            const statusEl = document.getElementById('mapStatus');
            const metricConversationsEl = document.getElementById('metricConversations');
            const metricMessagesEl = document.getElementById('metricMessages');
            const metricBookingsEl = document.getElementById('metricBookings');
            const metricFinishedBookingsEl = document.getElementById('metricFinishedBookings');
            const metricCancelledBookingsEl = document.getElementById('metricCancelledBookings');
            const metricRejectedJobsEl = document.getElementById('metricRejectedJobs');
            const metricConvertedPhonesEl = document.getElementById('metricConvertedPhones');
            const metricConversionRateEl = document.getElementById('metricConversionRate');
            const metricHumanHandoffEl = document.getElementById('metricHumanHandoff');
            const recentConversationsBodyEl = document.getElementById('recentConversationsBody');
            const recentBookingsBodyEl = document.getElementById('recentBookingsBody');

            const map = L.map('bookingsMap', {
                zoomControl: true,
                attributionControl: true
            });

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const clusterGroup = L.markerClusterGroup({
                showCoverageOnHover: false,
                spiderfyOnMaxZoom: true,
                spiderfyDistanceMultiplier: 2.4,
                zoomToBoundsOnClick: true,
                maxClusterRadius: 45
            });
            map.addLayer(clusterGroup);

            const markersById = new Map();
            let fallbackTimer = null;
            let isRefreshing = false;

            function toPin(raw) {
                return {
                    bookingId: raw.bookingId ?? raw.BookingId,
                    serviceCategory: raw.serviceCategory ?? raw.ServiceCategory ?? '',
                    serviceTitle: raw.serviceTitle ?? raw.ServiceTitle ?? '',
                    customerPhone: raw.customerPhone ?? raw.CustomerPhone ?? '',
                    address: raw.address ?? raw.Address ?? '',
                    startLocal: raw.startLocal ?? raw.StartLocal ?? '',
                    createdAtUtc: raw.createdAtUtc ?? raw.CreatedAtUtc ?? null,
                    latitude: raw.latitude ?? raw.Latitude,
                    longitude: raw.longitude ?? raw.Longitude
                };
            }

            function escapeHtml(value) {
                return (value ?? '')
                    .toString()
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function formatDateTime(value) {
                if (!value) {
                    return '-';
                }

                const parsed = new Date(value);
                if (Number.isNaN(parsed.getTime())) {
                    return value.toString();
                }

                return parsed.toLocaleString('pt-BR', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            }

            function toInt(value) {
                const parsed = Number(value);
                return Number.isFinite(parsed) ? Math.trunc(parsed) : 0;
            }

            function toDecimal(value) {
                const parsed = Number(value);
                return Number.isFinite(parsed) ? parsed : 0;
            }

            function addNormalizedPin(pin) {
                if (!pin.bookingId || markersById.has(pin.bookingId)) {
                    return false;
                }

                const lat = Number(pin.latitude);
                const lng = Number(pin.longitude);
                if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
                    return false;
                }

                const popup = `
                    <div style="min-width: 220px">
                        <strong>${escapeHtml(pin.serviceCategory)}</strong><br/>
                        ${escapeHtml(pin.serviceTitle)}<br/>
                        <small>${escapeHtml(pin.address)}</small><br/>
                        <small>Telefone: ${escapeHtml(pin.customerPhone)}</small>
                    </div>
                `;

                const marker = L.marker([lat, lng], { title: pin.serviceTitle || pin.serviceCategory });
                marker.bindPopup(popup);
                clusterGroup.addLayer(marker);
                markersById.set(pin.bookingId, marker);

                return true;
            }

            function syncPins(rawPins) {
                const previousIds = new Set(markersById.keys());
                clusterGroup.clearLayers();
                markersById.clear();

                let added = 0;
                let hasNewPin = false;

                for (const rawPin of rawPins) {
                    const pin = toPin(rawPin);
                    if (pin.bookingId && !previousIds.has(pin.bookingId)) {
                        hasNewPin = true;
                    }

                    if (addNormalizedPin(pin)) {
                        added++;
                    }
                }

                fitMapToAllPins(hasNewPin || previousIds.size === 0);
                return { added, hasNewPin };
            }

            function fitMapToAllPins(force) {
                const total = clusterGroup.getLayers().length;
                if (total === 0) {
                    map.setView([-14.235, -51.9253], 4);
                    return;
                }

                if (!force) {
                    return;
                }

                const bounds = clusterGroup.getBounds();
                if (bounds && bounds.isValid()) {
                    map.fitBounds(bounds, { padding: [28, 28], maxZoom: 16 });
                }
            }

            function updateStatus(extra) {
                const total = markersById.size;
                const now = new Date().toLocaleTimeString();
                statusEl.textContent = `Pins: ${total} | Atualizado: ${now}${extra ? ` | ${extra}` : ''}`;
            }

            function renderMetrics(snapshot) {
                const totalIncomingConversations = snapshot.totalIncomingConversations ?? snapshot.TotalIncomingConversations;
                const totalMessages = snapshot.totalMessages ?? snapshot.TotalMessages;
                const createdBookings = snapshot.createdBookings ?? snapshot.CreatedBookings;
                const finishedBookings = snapshot.finishedBookings ?? snapshot.FinishedBookings;
                const cancelledBookings = snapshot.cancelledBookings ?? snapshot.CancelledBookings;
                const rejectedJobs = snapshot.rejectedJobs ?? snapshot.RejectedJobs;
                const convertedPhones = snapshot.convertedPhones ?? snapshot.ConvertedPhones;
                const conversionRatePercent = snapshot.conversionRatePercent ?? snapshot.ConversionRatePercent;
                const humanHandoffOpen = snapshot.humanHandoffOpen ?? snapshot.HumanHandoffOpen;
                if (metricConversationsEl) {
                    metricConversationsEl.textContent = toInt(totalIncomingConversations).toString();
                }

                if (metricMessagesEl) {
                    metricMessagesEl.textContent = toInt(totalMessages).toString();
                }

                if (metricBookingsEl) {
                    metricBookingsEl.textContent = toInt(createdBookings).toString();
                }

                if (metricFinishedBookingsEl) {
                    metricFinishedBookingsEl.textContent = toInt(finishedBookings).toString();
                }

                if (metricCancelledBookingsEl) {
                    metricCancelledBookingsEl.textContent = toInt(cancelledBookings).toString();
                }

                if (metricRejectedJobsEl) {
                    metricRejectedJobsEl.textContent = toInt(rejectedJobs).toString();
                }

                if (metricConvertedPhonesEl) {
                    metricConvertedPhonesEl.textContent = toInt(convertedPhones).toString();
                }

                if (metricHumanHandoffEl) {
                    metricHumanHandoffEl.textContent = toInt(humanHandoffOpen).toString();
                }

                if (metricConversionRateEl) {
                    metricConversionRateEl.textContent = `${toDecimal(conversionRatePercent).toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: 2 })}%`;
                }

            }

            function renderRecentConversations(items) {
                if (!recentConversationsBodyEl) {
                    return;
                }

                if (!Array.isArray(items) || items.length === 0) {
                    recentConversationsBodyEl.innerHTML = '<tr><td colspan="3" class="text-muted">Sem conversas no periodo.</td></tr>';
                    return;
                }

                const rows = items.map(raw => {
                    const phone = raw.phone ?? raw.Phone ?? '';
                    const lastMessagePreview = raw.lastMessagePreview ?? raw.LastMessagePreview ?? '';
                    const isInHumanHandoff = Boolean(raw.isInHumanHandoff ?? raw.IsInHumanHandoff);
                    const detailsUrl = `${conversationDetailsUrl}?tenant=${encodeURIComponent(tenantId)}&phone=${encodeURIComponent(phone)}`;

                    return `
                        <tr>
                            <td><a href="${detailsUrl}">${escapeHtml(phone)}</a></td>
                            <td>${escapeHtml(lastMessagePreview)}</td>
                            <td>${isInHumanHandoff
                                ? '<span class="badge bg-warning text-dark">humano</span>'
                                : '<span class="badge bg-secondary">bot</span>'}</td>
                        </tr>
                    `;
                });

                recentConversationsBodyEl.innerHTML = rows.join('');
            }

            function renderRecentBookings(items) {
                if (!recentBookingsBodyEl) {
                    return;
                }

                if (!Array.isArray(items) || items.length === 0) {
                    recentBookingsBodyEl.innerHTML = '<tr><td colspan="4" class="text-muted">Sem agendamentos no periodo.</td></tr>';
                    return;
                }

                const rows = items.map(raw => {
                    const serviceCategory = raw.serviceCategory ?? raw.ServiceCategory ?? '';
                    const serviceTitle = raw.serviceTitle ?? raw.ServiceTitle ?? '';
                    const customerPhone = raw.customerPhone ?? raw.CustomerPhone ?? '';
                    const startLocal = raw.startLocal ?? raw.StartLocal ?? '';

                    return `
                        <tr>
                            <td>${escapeHtml(serviceCategory)}</td>
                            <td>${escapeHtml(serviceTitle)}</td>
                            <td>${escapeHtml(customerPhone)}</td>
                            <td>${escapeHtml(formatDateTime(startLocal))}</td>
                        </tr>
                    `;
                });

                recentBookingsBodyEl.innerHTML = rows.join('');
            }

            async function refreshDashboard(reason) {
                if (isRefreshing) {
                    return;
                }

                isRefreshing = true;
                try {
                    const query = new URLSearchParams({
                        tenant: tenantId,
                        days: String(days)
                    });

                    const response = await fetch(`${snapshotEndpoint}?${query.toString()}`, {
                        method: 'GET',
                        headers: { 'Accept': 'application/json' },
                        cache: 'no-store'
                    });

                    if (!response.ok) {
                        updateStatus(`falha HTTP ${response.status}`);
                        return;
                    }

                    const snapshot = await response.json();
                    renderMetrics(snapshot);

                    const recentConversations = Array.isArray(snapshot.recentConversations)
                        ? snapshot.recentConversations
                        : (Array.isArray(snapshot.RecentConversations) ? snapshot.RecentConversations : []);
                    const recentBookings = Array.isArray(snapshot.recentBookings)
                        ? snapshot.recentBookings
                        : (Array.isArray(snapshot.RecentBookings) ? snapshot.RecentBookings : []);
                    const mapPins = Array.isArray(snapshot.mapPins)
                        ? snapshot.mapPins
                        : (Array.isArray(snapshot.MapPins) ? snapshot.MapPins : []);

                    renderRecentConversations(recentConversations);
                    renderRecentBookings(recentBookings);
                    const pinResult = syncPins(mapPins);
                    updateStatus(reason ?? (pinResult.hasNewPin ? `+${pinResult.added} novo(s)` : null));
                } catch {
                    updateStatus('erro de atualizacao');
                } finally {
                    isRefreshing = false;
                }
            }

            function createRealtimeConnection() {
                if (!window.signalR) {
                    updateStatus('SignalR indisponivel');
                    return null;
                }

                const connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/dashboard')
                    .withAutomaticReconnect([0, 2000, 5000, 10000])
                    .build();

                connection.on('dashboardChanged', async payload => {
                    const eventTenantId = (payload?.tenantId ?? payload?.TenantId ?? '').toString().trim();
                    if (eventTenantId && eventTenantId.toLowerCase() !== tenantId.toLowerCase()) {
                        return;
                    }

                    await refreshDashboard('tempo real');
                });

                connection.onreconnecting(() => {
                    updateStatus('reconectando realtime');
                });

                connection.onreconnected(async () => {
                    try {
                        await connection.invoke('JoinTenant', tenantId);
                    } catch {
                        // ignore
                    }

                    await refreshDashboard('reconectado');
                });

                connection.onclose(() => {
                    updateStatus('realtime desconectado');
                });

                return connection;
            }

            async function startRealtime(connection) {
                if (!connection) {
                    return;
                }

                try {
                    await connection.start();
                    await connection.invoke('JoinTenant', tenantId);
                    updateStatus('realtime conectado');
                } catch {
                    updateStatus('falha na conexao realtime');
                    window.setTimeout(() => {
                        startRealtime(connection);
                    }, 5000);
                }
            }

            const initialPinResult = syncPins(initialPins);
            updateStatus(initialPinResult.added > 0
                ? `${initialPinResult.added} carregado(s)`
                : 'sem coordenadas geocodificadas ainda');

            const realtimeConnection = createRealtimeConnection();
            startRealtime(realtimeConnection);

            fallbackTimer = window.setInterval(() => {
                refreshDashboard('sync');
            }, 30000);

            refreshDashboard(null);
            window.addEventListener('beforeunload', () => {
                if (fallbackTimer) {
                    window.clearInterval(fallbackTimer);
                }

                if (realtimeConnection) {
                    realtimeConnection.invoke('LeaveTenant', tenantId).catch(() => {
                        // ignore
                    });
                    realtimeConnection.stop().catch(() => {
                        // ignore
                    });
                }
            });
        })();
    </script>
}
